
"smart_sources:docs/science/human/6.md": {"path":"docs/science/human/6.md","last_embed":{"hash":null},"embeddings":{},"last_read":{"hash":"ityib8","at":1774774481706},"class_name":"SmartSource","last_import":{"mtime":1774762570803,"size":1117,"at":1774774481781,"hash":"ityib8"},"blocks":{"#---frontmatter---":[1,24],"#消化系统":[26,27]},"outlinks":[],"metadata":{"title":"消化系统详解：酶促分解机制与营养吸收应用","description":"本文系统阐述消化系统中酶促营养分解的生化路径，详细解析胃酸、胰酶及肠道酶的协同作用，并探讨酶活性调控、底物特异性以及营养吸收的物理机制，为高中生物与大学生物化学提供完整技术框架。重点分析胰蛋白酶、淀粉酶与脂肪酶的催化机理，以及胆汁盐对脂类乳化的辅助作用，并提供实验参考指标，帮助学生构建系统性知识模型。","summary":"系统解析消化酶协同分解机理，重点阐述胰蛋白酶、淀粉酶及脂肪酶的催化过程与胆汁辅助作用，提供实验指标供学生掌握。","tags":["#生物化学","#消化系统","#酶促分解","#营养吸收","#胰蛋白酶","#淀粉酶","#脂肪酶","#胆汁盐","#底物特异性","#活性调控","#催化机理","#高中生物","#大学生物化学","#实验设计","#考试复习","#实验室教学","#理科学生","#竞赛备考"]},"task_lines":[],"tasks":{},"codeblock_ranges":[]},
