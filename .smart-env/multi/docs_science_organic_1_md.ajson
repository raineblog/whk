":"alt text","target":"image-6.avif","line":202,"embedded":true},{"title":"alt text","target":"image-7.avif","line":208,"embedded":true},{"title":"alt text","target":"image-8.avif","line":218,"embedded":true},{"title":"alt text","target":"结构.svg","line":220,"embedded":true},{"title":"alt text","target":"image-11.avif","line":228,"embedded":true},{"title":"alt text","target":"image-9.avif","line":236,"embedded":true},{"title":"alt text","target":"image-10.avif","line":240,"embedded":true},{"title":"alt text","target":"Adamantane_acsv.svg","line":374,"embedded":true},{"title":"金刚烷 - 维基百科","target":"https://zh.wikipedia.org/zh-hans/%E9%87%91%E5%88%9A%E7%83%B7#%E5%8C%96%E5%AD%A6%E6%80%A7%E8%B4%A8","line":376},{"title":"alt text","target":"Pentaerythritol.svg","line":420,"embedded":true},{"title":"alt text","target":"image-36.avif","line":432,"embedded":true},{"title":"alt text","target":"image-37.avif","line":440,"embedded":true}],"metadata":{"title":"有机化学详解：碳原子成键机理与命名应用场景基础","description":"本文系统阐释有机化合物的基本概念包括碳原子的四价成键单双三键特性及不饱和度计算公式详细解析链烷烃烯烃炔烃及芳香体系的通式并说明同系物在复杂分子中的局限性与衍生物命名规则同时介绍元素分析质谱核磁共振与红外光谱等现代表征方法阐明其在结构鉴定中的应用","summary":"系统解析有机化合物结构不饱和度与命名规则涵盖现代表征技术与同系物局限性强调官能团与空间位阻的关联的意义","tags":["#有机化学","#碳原子","#官能团","#不饱和度","#命名规则","#同系物","#结构简式","#结构式","#元素分析","#质谱","#核磁共振","#红外光谱","#实验室分析","#结构鉴定","#同系物局限","#官能团识别","#高中化学","#大学化学","#竞赛备考","#科研人员"]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"v6g2ei","at":1774778476278},"key":"docs/science/organic/1.md"},
