氰酸、氰酸与异氰酸":[324,411],"#氮族元素概述#氮的其他化合物#氢氰酸、氰酸与异氰酸#结构与命名":[326,335],"#氮族元素概述#氮的其他化合物#氢氰酸、氰酸与异氰酸#结构与命名#{1}":[328,335],"#氮族元素概述#氮的其他化合物#氢氰酸、氰酸与异氰酸#物理性质对比":[336,346],"#氮族元素概述#氮的其他化合物#氢氰酸、氰酸与异氰酸#物理性质对比#{1}":[338,346],"#氮族元素概述#氮的其他化合物#氢氰酸、氰酸与异氰酸#化学性质差异":[347,374],"#氮族元素概述#氮的其他化合物#氢氰酸、氰酸与异氰酸#化学性质差异#{1}":[349,374],"#氮族元素概述#氮的其他化合物#氢氰酸、氰酸与异氰酸#应用领域":[375,401],"#氮族元素概述#氮的其他化合物#氢氰酸、氰酸与异氰酸#应用领域#{1}":[377,401],"#氮族元素概述#氮的其他化合物#氢氰酸、氰酸与异氰酸#安全注意事项":[402,411],"#氮族元素概述#氮的其他化合物#氢氰酸、氰酸与异氰酸#安全注意事项#{1}":[404,411]},"outlinks":[],"metadata":{"title":"氮族元素概述详解固氮机理与工业应用与生态全景","description":"本文系统阐述氮族元素的固氮过程，包括自然高能固氮、生物固氮及工业哈伯法合成氨的反应原理、压强、温度、催化剂及气体配比的最佳条件。随后详细分析氮氧化物的物理性质、氧化还原反应路径及其在酸雨形成中的作用，并探讨氨气的溶解性、制取方法、化学性质及其在工业和实验室中的应用，最后介绍氮的其他重要化合物如氢氰酸、氰酸、异氰酸的结构、稳定性、酸性及工业用途，兼顾安全注意事项","summary":"固氮机理哈伯法工业制氨氮氧化物性质及氨气化学性质全解析涵盖酸雨形成氮氧化物反应路径及氧化还原应用在教学中的价值","tags":["#无机化学","#氮化学","#固氮","#哈伯法","#氮氧化物","#酸雨","#工业合成","#氨气性质","#硝酸制取","#氢氰酸","#氰酸","#异氰酸","#高中化学","#大学化学","#竞赛复习","#实验室分析","#环境科学","#气体反应","#催化剂","#化学原理"]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1x1h6ke","at":1774774779428}},"smart_blocks:docs/science/element/n.md#---frontmatter---": {"path":null,"embeddings":{"Xenova/multilingual-e5-small":{"vec":[0.04932581,-0.02267821,-0.04824906,-0.06235136,0.05455652,-0.00423799,0.00881183,0.05204095,0.09137173,0.01454309,-0.00241934,-0.02684632,0.01737565,-0.00449365,-0.0961087,0.057534,0.06740438,-0.04841609,-0.01420453,-0.02424007,0.01858053,0.00731109,-0.02676408,0.00133388,0.08155326,0.04330005,-0.06559098,0.01870359,0.08007982,-0.04260499,-0.03773698,-0.05723115,0.0759479,-0.0391275,0.07206101,0.04072973,-0.06926262,-0.03013441,0.03494304,-0.04387427,-0.03738107,-0.00735452,0.0518082,0.06830642,0.0290674,0.04479558,-0.02155282,0.04377872,-0.0084062,-0.03311604,-0.02892653,0.05538086,0.03016593,0.05938015,0.03947656,-0.06917653,-0.0451488,-0.0712064,-0.0645742,0.08363882,0.05258085,-0.02281966,-0.00985004,0.02622873,0.08525323,0.06296527,0.04116884,0.02068835,-0.03203081,-0.03186315