ext","target":"image-4.avif","line":97,"embedded":true},{"title":"alt text","target":"image-14.avif","line":211,"embedded":true},{"title":"alt text","target":"image-15.avif","line":220,"embedded":true},{"title":"alt text","target":"image-16.avif","line":228,"embedded":true},{"title":"alt text","target":"image-19.avif","line":284,"embedded":true},{"title":"alt text","target":"raineblog.dpdns.org_whk_science_human_3_.avif","line":306,"embedded":true},{"title":"alt text","target":"image-13.avif","line":312,"embedded":true},{"title":"alt text","target":"image-12.avif","line":352,"embedded":true},{"title":"alt text","target":"image-21.avif","line":360,"embedded":true},{"title":"alt text","target":"无标题-2025-09-14-2104.svg","line":501,"embedded":true},{"title":"alt text","target":"raineblog.dpdns.org_whk_science_human_3_(1","line":505,"embedded":true},{"title":"alt text","target":"image-20.avif","line":551,"embedded":true},{"title":"alt text","target":"image-7.avif","line":601,"embedded":true}],"metadata":{"title":"内环境稳态详解：激素调节机制与临床实践","description":"本文系统阐释内环境概念，解析血浆、组织液、淋巴液的组成与动态平衡，重点探讨渗透压、酸碱度、温度等理化性质的稳态调控机制，深入说明激素在血糖、体温、水盐调节中的关键作用及反馈回路，涵盖胰岛素、胰高血糖素、甲状腺激素、糖皮质激素等，适用于生物化学与医学学习。","summary":"内环境稳态机制与激素调节的系统解析，涵盖渗透压、酸碱度、温度等理化性质及血糖、体温、水盐的动态平衡，适用于生化与医学学习。","tags":["#生物化学","#内环境","#稳态","#激素调节","#渗透压","#酸碱度","#体温调节","#血糖调控","#水盐平衡","#高中生物","#大学医学","#临床糖尿病","#反馈机制","#神经调节","#体液调节","#糖皮质激素","#胰岛素","#胰高血糖素","#甲状腺激素","#内分泌系统","#医学学习"]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"142uemg","at":1774775054284}},"smart_blocks:docs/science/human/3.md#---frontmatter---": {"path":null,"embeddings":{"Xenova/multilingual-e5-small":{"vec":[0.06580815,0.00312711,-0.06054746,-0.06315438,0.08955086,0.03418345,0.04265258,0.05092927,0.10881118,0.01463211,-0.0101338,0.00213524,0.04262507,-0.01041647,-0.09006611,0.05483639,0.07829759,-0.04736985,-0.00070218,-0.0453942,-0.01220155,0.00018895,-0.05995877,0.07021748,0.06642359,0.03376518,-0.02224987,0.04825256,0.07633289,-0.0509