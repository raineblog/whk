dded":true},{"title":"alt text","target":"image.avif","line":635,"embedded":true},{"title":"alt text","target":"image-1038de9.avif","line":650,"embedded":true},{"title":"alt text","target":"image-1-99bf5e2.avif","line":652,"embedded":true}],"metadata":{"title":"共价键详解：分子轨道机制与现代实验室化学的应用","description":"本文系统阐述共价键的形成机制，包括分子轨道理论解释氧分子顺磁性、头并头重叠形成的成键以及肩并肩重叠形成的π键特性。进一步分析键能、键长与键角的测定方法，并结合配位键在实验室配合物的形成、溶解与颜色变化中的应用，提供完整的实验路线与理论框架。","summary":"全面解释共价键形成机制，涵盖分子轨道、成键及π键特性、键参数及配位应用，适用于实验教学与竞赛复习，帮助学生掌握化学空间结构与反应机理的核心概念。","tags":["#高中化学","#共价键","#分子轨道","#键能","#键长","#键角","#成键","#π键","#配位键","#超价分子","#多中心键","#杂化","#八隅体规则","#实验设计","#竞赛复习","#理综学习","#化学原理","#配合物","#溶解现象","#颜色变化"]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1qvf6jt","at":1774775645700}},"smart_blocks:docs/science/structure/3.md#---frontmatter---": {"path":null,"embeddings":{"Xenova/multilingual-e5-small":{"vec":[0.05343936,-0.02651209,-0.06006354,-0.01851687,0.03711489,-0.0232662,0.02459158,0.04018459,0.13776335,-0.01093473,0.02520055,-0.05441219,0.03501043,0.01812126,-0.07483662,0.061862,0.05868988,-0.06314629,-0.028497,-0.04264711,0.00333588,0.00234033,-0.04652783,0.01983275,0.06186847,0.01107293,-0.05568362,0.02727528,0.07315826,-0.03662429,-0.00430952,-0.05406072,0.08515774,-0.0385077,0.02142229,0.04329219,-0.05846059,-0.05052544,0.02524156,-0.01904545,-0.02046516,-0.01439243,0.06938033,0.0609911,0.04123903,0.04878446,-0.0038392,0.02368985,-0.04403531,-0.0047157,-0.04587224,0.01874265,0.04559706,0.05590384,0.01599141,-0.08714077,-0.01468714,-0.08453126,-0.0562651,0.08779404,0.06851811,-0.03030342,0.01845101,0.04538317,0.1012404,0.03436792,0.05340229,0.0402866,-0.03399174,-0.02528801,-0.04395441,0.04795037,0.00693274,-0.03092364,0.04956212,-0.00366372,0.09027454,-0.06736457,0.03264265,-0.05132939,-0.07900702,-0.05492403,-0.07000912,-0.00073298,-0.04695214,0.03905904,0.06270236,-0.08996561,0.03915204,-0.01282355,0.03033813,0.04839674,-0.01292494,-0.06856889,-0.08170188,-0.07195416,-0.04985197,0.