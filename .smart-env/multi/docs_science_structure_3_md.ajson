dded":true},{"title":"alt text","target":"image.avif","line":635,"embedded":true},{"title":"alt text","target":"image-1038de9.avif","line":650,"embedded":true},{"title":"alt text","target":"image-1-99bf5e2.avif","line":652,"embedded":true}],"metadata":{"title":"共价键详解：分子轨道机制与现代实验室化学的应用","description":"本文系统阐述共价键的形成机制，包括分子轨道理论解释氧分子顺磁性、头并头重叠形成的成键以及肩并肩重叠形成的π键特性。进一步分析键能、键长与键角的测定方法，并结合配位键在实验室配合物的形成、溶解与颜色变化中的应用，提供完整的实验路线与理论框架。","summary":"全面解释共价键形成机制，涵盖分子轨道、成键及π键特性、键参数及配位应用，适用于实验教学与竞赛复习，帮助学生掌握化学空间结构与反应机理的核心概念。","tags":["#高中化学","#共价键","#分子轨道","#键能","#键长","#键角","#成键","#π键","#配位键","#超价分子","#多中心键","#杂化","#八隅体规则","#实验设计","#竞赛复习","#理综学习","#化学原理","#配合物","#溶解现象","#颜色变化"]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1qvf6jt","at":1774778429325}},