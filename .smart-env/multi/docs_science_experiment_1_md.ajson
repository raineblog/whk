分离#结晶：单一溶质#{1}":[271,280],"#化学实验操作#基本实验#物理分离#结晶：多种溶质":[281,292],"#化学实验操作#基本实验#物理分离#结晶：多种溶质#{1}":[283,292],"#化学实验操作#基本实验#物理分离#洗涤":[293,304],"#化学实验操作#基本实验#物理分离#洗涤#{1}":[295,304],"#化学实验操作#基本实验#物理分离#升华":[305,310],"#化学实验操作#基本实验#物理分离#升华#{1}":[307,310],"#化学实验操作#基本实验#物理分离#渗析":[311,318],"#化学实验操作#基本实验#物理分离#渗析#{1}":[313,318],"#化学实验操作#基本实验#物理分离#蒸馏":[319,330],"#化学实验操作#基本实验#物理分离#蒸馏#{1}":[321,330],"#化学实验操作#基本实验#萃取与分布系数":[331,358],"#化学实验操作#基本实验#萃取与分布系数#{1}":[333,358],"#化学实验操作#基本实验#检验和鉴别":[359,379],"#化学实验操作#基本实验#检验和鉴别#{1}":[361,379],"#化学实验操作#基本实验#气体的除杂":[380,409],"#化学实验操作#基本实验#气体的除杂#{1}":[382,409],"#化学实验操作#离子相关":[410,467],"#化学实验操作#离子相关#观察法":[412,423],"#化学实验操作#离子相关#观察法#{1}":[414,423],"#化学实验操作#离子相关#沉淀气体法":[424,435],"#化学实验操作#离子相关#沉淀气体法#{1}":[426,435],"#化学实验操作#离子相关#离子的共存":[436,467],"#化学实验操作#离子相关#离子的共存#{1}":[438,467]},"outlinks":[{"title":"量气","target":"./tech/量气装置.svg","line":221,"embedded":true},{"title":"防倒吸装置","target":"./tech/安全瓶.avif","line":237,"embedded":true}],"metadata":{"title":"化学实验操作详解：安全应对与废弃物处理实用指南","description":"本文系统阐述化学实验中的突发事件应急处理流程，涵盖烫伤、创伤、酸碱灼伤的急救步骤及中和、沉淀、萃取等废液处理技术；进一步解析离心分离原理、差速与密度梯度离心的操作步骤，以及分析超速离心的沉降系数测定方法，为实验室安全与废弃物管理提供完整技术路线。","summary":"全面覆盖实验安全应急与废弃物处理技术，详解离心分离原理及分析超速离心方法，为实验室操作提供系统指南。","tags":["#化学实验","#实验安全","#实验技术","#化学实验操作","#废弃物处理","#离心分离","#酸碱灼伤","#中和法","#沉淀法","#萃取","#差速离心","#密度梯度","#分析超速","#沉降系数","#实验室管理","#实验教学","#高中生","#大学生","#实验员","#科研人员"]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"16f44z","at":1775649256384},"key":"docs/science/experiment/1.md"},
