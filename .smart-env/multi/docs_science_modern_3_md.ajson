ded":true},{"title":"alt text","target":"7f497ec15f6c0d1f_e77bd7e.svg","line":640,"embedded":true},{"title":"衍射光栅示意图","target":"image-3.avif","line":670,"embedded":true},{"title":"机械波的偏振","target":"image-5.avif","line":729,"embedded":true},{"title":"偏振片原理","target":"image-6.avif","line":742,"embedded":true},{"title":"偏振镜的效果","target":"image-7.avif","line":759,"embedded":true},{"title":"alt text","target":"image-3-d4e31b1.avif","line":788,"embedded":true},{"title":"alt text","target":"image-4-8076e3a.avif","line":790,"embedded":true}],"metadata":{"title":"光学原理详解：光的传播机制与光学系统全解析","description":"本文系统阐述光的传播特性，包括点光源、波前、能流矢量及光线抽象；详细推导小孔成像中的全反射条件；阐明镜面反射、漫反射及逆反射原理；解释折射率、斯涅尔定律及全内反射；并分析光导纤维结构、衍射光栅与X射线衍射在生物结构中的应用，同时涉及实验测折射率的步骤与误差分析，提供从几何光学到波动光学的完整框架。","summary":"全面解析光的传播、反射、折射及光学系统，涵盖小孔成像全反射、实验测折射率方法及光纤、衍射光栅等应用，适用于高中物理与大学光学学习。","tags":["#光学","#物理学","#高中物理","#大学光学","#光的传播","#光的反射","#光的折射","#光学系统","#点光源","#波面","#能流矢量","#全反射","#折射率","#斯涅尔定律","#光导纤维","#衍射","#干涉","#实验设计","#高考复习","#实验测折射率","#竞赛备考"]},"task_lines":[],"tasks":{},"codeblock_ranges":[]},
