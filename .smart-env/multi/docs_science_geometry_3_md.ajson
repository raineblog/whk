e":967,"embedded":true},{"title":"alt text","target":"image-35.avif","line":981,"embedded":true},{"title":"alt text","target":"image-36.avif","line":997,"embedded":true},{"title":"alt text","target":"image-38.avif","line":1005,"embedded":true},{"title":"alt text","target":"image-10.avif","line":1016,"embedded":true},{"title":"alt text","target":"image-3.avif","line":1026,"embedded":true},{"title":"alt text","target":"image-11.avif","line":1036,"embedded":true},{"title":"alt text","target":"image-9.avif","line":1052,"embedded":true},{"title":"alt text","target":"image-8.avif","line":1060,"embedded":true},{"title":"alt text","target":"<desmos-graph (6","line":1085,"embedded":true},{"title":"alt text","target":"image-1.avif","line":1125,"embedded":true},{"title":"alt text","target":"image-22.avif","line":1135,"embedded":true},{"title":"alt text","target":"image-16.avif","line":1149,"embedded":true},{"title":"alt text","target":"image-17.avif","line":1159,"embedded":true},{"title":"alt text","target":"image-18.avif","line":1167,"embedded":true},{"title":"alt text","target":"image-19.avif","line":1173,"embedded":true},{"title":"alt text","target":"image-20.avif","line":1181,"embedded":true},{"title":"alt text","target":"image-40.avif","line":1193,"embedded":true},{"title":"alt text","target":"image-45.avif","line":1195,"embedded":true},{"title":"alt text","target":"image-42.avif","line":1197,"embedded":true},{"title":"alt text","target":"image-43.avif","line":1199,"embedded":true},{"title":"alt text","target":"image-44.avif","line":1201,"embedded":true},{"title":"alt text","target":"image-41.avif","line":1203,"embedded":true},{"title":"alt text","target":"image-46.avif","line":1205,"embedded":true},{"title":"alt text","target":"image-2-9525fa1.avif","line":1235,"embedded":true}],"metadata":{"title":"椭圆详解：几何定义与参数化全解析与竞赛复习","description":"本文系统阐释椭圆的三大定义：第一定义通过焦点距离之和求标准方程，第二定义利用离心率与准线建立几何比例，第三定义采用点差法分析弦の中点关系。随后推导参数化方程、切线斜率及极点极线理论，并讨论面积、周长近似及光学性质，为高考与竞赛提供完整技术路线，以及应用实例。","summary":"本文系统阐释椭圆的几何定义、参数方程、切线斜率及光学性质，提供完整的竞赛复习框架与技术路线以及应用实例。","tags":["#椭圆","#椭圆方程","#焦点","#离心率","#参数化","#切线","#极点极线","#光学性质","#竞赛复习","#高考数学","#几何定义","#几何性质","#椭圆周长","#椭圆面积","#中点弦","#焦点三角形"]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1xgyyv2","at":1774775097183}},"smart_blocks:docs/science/geometry/3.md#---frontmatter---": {"path":null,"embeddings":{"Xenova/multilingual-e5-small":{"vec":[0.03856264,0.02942917,-0.05715179,-0.0407184,0.0497612,-0.00114875,0.00599509,0.08013935,0.11605313,-0.0192406,0.02847817,-0.03374163,0.06171536,0.02013799,-0.06034747,0.07977552,0.03301809,-0.06888639,-0.00993122,-0.03036934,0.04539732,0.00743616,-0.04886326,0.01872102,0.05277392,0.03202708,-0.03168153,0.03600565,0.03973453,-0.06300087,-0.05834622,-0.06100745,0.03979241,-0.06103664,0.04198598,0.03790404,-0.06894764,-0.03765241,0.01720281,-0.05844239,-0.03681266,0.00894183,0.03754327,0.09121601,0.03298481,0.05237808,-0.04848347,0.01657077,-0.04177182,-0.01909373,-0.01591746,0.01371033,0.01743478,0.01574822,-0.01767079,-0.07589871,-0.00118268,-0.05175947,-0.05934284,0.08763048,0.0538269,-0.06110513,0.00568435,0.07275042,0.06442216,0.03866308,0.04201014,0.03341087,-0.03961073,-0.0298694,-0.01398059,0.06649838,0.06067881,-0.0280589,0.01252075,-0.00144825,0.04872355,-0.04084084,0.03412452,-0.06031976,-0.0736957,0.0259545,-0.00508549,0.0250179,-0.05715237,0.0311896,0.02859984,-0.06857982,0.06073543,-0.02577934,0.05352632,0.05622932,-0.04477208,-0.05436074,-0.09313298,-0.04084263,-0.0306673,0.04741892,0.06734046,-0.02144924,0.0688963,-0.03206804,0.02966807,-0.09922002,0.00286899,0.03804936,0.02208148,-0.05849389,0.03642077,-0.07171158,-0.01584858,0.05898932,0.07014401,0.04014816,-0.078052,-0.03346574,-0.02144791,-0.05816947,0.02025074,-0.04154954,0.06414344,-0.06465992,-0.02555816,-0.03851186,-0.05385657,-0.06301983,-0.00263906,0.03109091,-0.03587652,0.04734192,0.08777498,0.07615194,0.02944575,0.04446173,0.04682165,0.0745689,-0.07116473,0.00114172,-0.01125288,-0