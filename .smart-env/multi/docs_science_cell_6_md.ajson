08f1.avif","line":743,"embedded":true},{"title":"alt text","target":"image-41-67c991d.avif","line":745,"embedded":true},{"title":"alt text","target":"image-6-0faf96a.avif","line":757,"embedded":true},{"title":"限制性内切核酸酶识别特定 DNA 序列并在切割位点切开 DNA","target":"image-19-227fb4f.avif","line":763,"embedded":true},{"title":"DNA 连接酶作用示意图","target":"image-20-32bf9ce.avif","line":771,"embedded":true},{"title":"alt text","target":"image-7-0ace124.avif","line":788,"embedded":true},{"title":"PCR 的基本程序","target":"image-21-a6e54f7.avif","line":804,"embedded":true},{"title":"alt text","target":"image-b242dda.avif","line":814,"embedded":true},{"title":"alt text","target":"image-1-61c552e.avif","line":818,"embedded":true},{"title":"alt text","target":"image-42-40e340c.avif","line":847,"embedded":true},{"title":"alt text","target":"image-2-d777481.avif","line":855,"embedded":true},{"title":"alt text","target":"image-43-db452de.avif","line":863,"embedded":true},{"title":"alt text","target":"image-3-9f83429.avif","line":873,"embedded":true},{"title":"抗药性筛选法的工作原理","target":"image-22-c18a52d.avif","line":881,"embedded":true}],"metadata":{"title":"植物细胞工程详解：细胞全能性与组织再生技术应用","description":"本文系统阐述植物细胞全能性假说的形成与验证重点解析离体培养中细胞脱分化愈伤组织形成及再分化的激素调控机制包括生长素与细胞分裂素比例对愈伤组织生长的关�影响文章详细描述原生质体制备聚乙二醇诱导融合及电融合技术阐释融合后细胞核的异核体形成与减数分裂同步化过程并说明通过质粒载体构建脱氧核糖核酸表达系统以实现转基因抗虫抗病及快速繁殖的实现路径","summary":"植物细胞全能性与组织培养技术详解，涵盖脱分化、愈伤组织形成、再分化及激素调控机制，适用于高中与大学生物学习与复习","tags":["#高中生物","#生物工程","#植物细胞工程","#细胞全能性","#脱分化","#愈伤组织","#再分化","#生长素","#细胞分裂素","#原生质体","#PEG融合","#电融合","#质粒载体","#转基因","#农业育种","#脱毒","#种质保存","#单倍体育种","#快速繁殖","#医药生产"]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1kec7e1","at":1774774847651}},"smart_blocks:docs/science/cell/6.md#---frontmatter---": {"path":null,"embeddings":{"Xenova/multilingual-e5-small":{"vec":[0.06105821,0.00305388,-0.0588334,-0.02550234,0.12537402,0.00511297,0.03326238,0.0572445,0.07107061,-0.04271292,0.00791787,0.00006116,0.03273597,0.00010173,-0.06283163,0.05395596,0.08004671,-0