le":"alt text","target":"image-17.avif","line":158,"embedded":true},{"title":"alt text","target":"image-18.avif","line":160,"embedded":true},{"title":"alt text","target":"image-19.avif","line":186,"embedded":true},{"title":"alt text","target":"image-20.avif","line":188,"embedded":true},{"title":"alt text","target":"image-21.avif","line":190,"embedded":true},{"title":"alt text","target":"image-22.avif","line":192,"embedded":true},{"title":"alt text","target":"image-23.avif","line":200,"embedded":true},{"title":"alt text","target":"image-24.avif","line":202,"embedded":true},{"title":"alt text","target":"image-25.avif","line":204,"embedded":true},{"title":"alt text","target":"image-26.avif","line":206,"embedded":true},{"title":"alt text","target":"image-27.avif","line":218,"embedded":true},{"title":"alt text","target":"5.19.avif","line":398,"embedded":true},{"title":"alt text","target":"image-38.avif","line":483,"embedded":true},{"title":"alt text","target":"image-39.avif","line":487,"embedded":true},{"title":"alt text","target":"image-40.avif","line":491,"embedded":true},{"title":"alt text","target":"image-28.avif","line":612,"embedded":true}],"metadata":{"title":"高分子详解：加聚与缩聚机制与工业应用医用黏合剂","description":"本文系统阐述高分子的形成机理，涵盖加聚反应（如乙烯加聚生成聚乙烯）与缩聚反应（如酚醛树脂的脱水缩合），并详细分析碳链延长、环化、官能团转化及保护策略。同时探讨医用黏合剂的聚合物化学、生物降解路径及工业制备工艺，提供从原料到应用的完整技术路线。","summary":"本文深入探讨高分子的合成路径、结构调控以及在医疗领域的黏合剂应用，强调其生物降解与安全性。并对比不同材料的黏合强度与降解速率，为工程选材提供依据。","tags":["#高分子化学","#材料科学","#医用黏合剂","#聚合反应","#加聚","#缩聚","#碳链延长","#环化反应","#官能团转化","#保护策略","#工业制备","#油脂提取","#煤油精制","#医疗应用","#生物降解","#安全性评估","#高中生物","#大学化学","#科研方法","#工程材料"]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"ay6uns","at":1774792259266},"key":"docs/science/organic/4.md"},
