bedded":true},{"title":"电容器原理","target":"Diel.avif","line":183,"embedded":true},{"title":"电容器","target":"Dielectric.avif","line":185,"embedded":true},{"title":"alt text","target":"fimage-7.avif","line":201,"embedded":true},{"title":"alt text","target":"fimage-8.avif","line":254,"embedded":true},{"title":"穿出","target":"屏幕截图 2025-01-26 182733.avif","line":356,"embedded":true},{"title":"交变电场","target":"屏幕截图 2025-01-26 193313.avif","line":414,"embedded":true},{"title":"偏转电场","target":"2025-01-27-17-51-14.avif","line":438,"embedded":true},{"title":"加速电场偏转电池","target":"2025-01-27-17-54-56.avif","line":474,"embedded":true}],"metadata":{"title":"电场运动详解：匀强场加速与偏转原理与实验技术方法","description":"本文系统阐述电场中带电粒子的运动规律，涵盖匀强与非匀强场的力学模型、电势与电场强度的计算推导，以及电容器的结构、容量公式及串并联等效模型。重点解析加速电场下的功动能定理、穿板与交变场运动，并延伸至偏转电场的轨迹求解与阴极射线管应用，提供从基础原理到实验技巧的完整技术路线。","summary":"全面解析电场运动的力学模型、电容结构与加速偏转原理，涵盖匀强场计算、功动能定理及实验技巧，适用于高中物理竞赛与大学物理教学。","tags":["#高中物理","#电场运动","#匀强电场","#非匀强电场","#电容","#电容器","#电场强度","#电势","#加速电场","#偏转电场","#阴极射线管","#高考复习","#竞赛备考","#实验设计","#理综学习","#大学物理","#物理学","#运动轨迹","#功动能定理","#电容串联","#电容并联","#电容原理","#电场力","#电荷","#电场线"]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"y84ebh","at":1774774801116}},"smart_blocks:docs/science/electromagnetism/3.md#---frontmatter---": {"path":null,"embeddings":{"Xenova/multilingual-e5-small":{"vec":[0.04265125,0.00808051,-0.05207659,-0.03364706,0.08380034,-0.00168245,0.03899942,0.07342697,0.10299334,-0.02692293,-0.00217456,-0.01846153,0.04998916,-0.007804,-0.05009655,0.09996898,0.0596616,-0.05079645,-0.0296438,-0.06584121,0.02133963,-0.01408587,-0.06692334,0.01653294,0.06508054,0.03320492,-0.0490846,0.02755354,0.05982721,-0.06581026,-0.01937839,-0.07713104,0.06784538,-0.05143377,0.08866488,0.02860716,-0.06385458,-0.03310179,0.01013902,-0.05511697,0.00476353,-0.00320564,0.05258641,0.08092358,0.0492582,0.04974198,-0.03159583,0.02449252,-0.00881559,-0.03021544,-0.0356049,0.03671856,0.02426406,0.05194893,-0.00964491,-0.03784654,-0.0277407,-0.05522832,-0