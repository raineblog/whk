":true},{"title":"alt text","target":"image-29.avif","line":93,"embedded":true},{"title":"alt text","target":"image-22.avif","line":123,"embedded":true},{"title":"alt text","target":"image-30.avif","line":129,"embedded":true},{"title":"alt text","target":"image-31.avif","line":141,"embedded":true},{"title":"alt text","target":"image-25.avif","line":206,"embedded":true},{"title":"alt text","target":"antibody_chart_recreated-895e7c5.avif","line":266,"embedded":true},{"title":"alt text","target":"image-27.avif","line":298,"embedded":true},{"title":"alt text","target":"image-28.avif","line":310,"embedded":true},{"title":"alt text","target":"image-23.avif","line":445,"embedded":true},{"title":"alt text","target":"image-24.avif","line":455,"embedded":true},{"title":"alt text","target":"image-32.avif","line":463,"embedded":true}],"metadata":{"title":"免疫系统详解：机制原理、应用场景与临床意义深入","description":"本文系统阐述免疫系统结构与功能，涵盖骨髓、胸腺、脾、淋巴结等器官的发育与分布，深入解析T细胞（辅助性、细胞毒性、调节性、记忆细胞）及B细胞的分化、抗体产生与记忆形成，探讨巨噬细胞、树突状细胞等抗原呈递细胞的角色，以及细胞因子、补体系统在免疫调节中的网络作用。","summary":"本文系统阐述免疫系统结构、细胞谱系及信号网络，重点解析T/B细胞分化、抗体产生及记忆形成，涵盖巨噬细胞、树突状细胞等抗原呈递及细胞因子、补体系统的调节作用，适用于医学与生物学学习。","tags":["#免疫学","#生物化学","#医学","#免疫系统","#免疫细胞","#抗体","#细胞因子","#补体系统","#T细胞","#B细胞","#巨噬细胞","#树突状细胞","#抗原呈递","#记忆细胞","#高中生物","#大学医学","#临床诊断","#科研学习","#免疫治疗","#疫苗研发","#理综学习","#竞赛备考","#医学生","#生物学爱好者","#教师资源"]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"qfd8uq","at":1774775069772}},"smart_blocks:docs/science/human/9.md#---frontmatter---": {"path":null,"embeddings":{"Xenova/multilingual-e5-small":{"vec":[0.04746434,-0.0020924,-0.07151695,-0.05102465,0.09831709,0.00700483,0.00192299,0.05650597,0.0959447,-0.02655976,0.02532123,0.00070475,0.07214588,-0.00287278,-0.0621198,0.03675382,0.0964506,-0.10447714,-0.01013718,-0.05155485,-0.01271535,-0.00020812,-0.06444636,0.07315958,0.10510785,0.04397748,-0.03212439,0.03216359,0.06297686,-0.03052292,-0.05374792,-0.04776631,0.04690255,-0.06272474,0.08696563,0.00846412,-0.06961238,-0.07414335,0.04016,