
"smart_sources:docs/science/kinematics/1.md": {"path":"docs/science/kinematics/1.md","last_embed":{"hash":null},"embeddings":{},"last_read":{"hash":"qivpga","at":1774774481783},"class_name":"SmartSource","last_import":{"mtime":1774762570809,"size":8584,"at":1774774481812,"hash":"qivpga"},"blocks":{"#---frontmatter---":[1,27],"#物理方法":[29,121],"#物理方法#物理学史":[31,51],"#物理方法#物理学史#{1}":[33,51],"#物理方法#长度测量":[52,61],"#物理方法#长度测量#刻度尺":[54,55],"#物理方法#长度测量#游标卡尺":[56,57],"#物理方法#长度测量#螺旋测微器":[58,59],"#物理方法#长度测量#打点计时器":[60,61],"#物理方法#基本方法":[62,121],"#物理方法#基本方法#量纲分析":[64,121],"#物理方法#基本方法#量纲分析#{1}":[66,121]},"outlinks":[],"metadata":{"title":"物理学史详解：时空统一机制与实验技术全应用解析","description":"本文系统梳理物理学从古代自然哲学到现代实验技术的演进脉络，重点解析牛顿力学统一、电磁场理论、量子假设及相对论的核心原理，并阐述量纲分析在长度、质量、功率等物理量测量中的应用方法。除此之外，文章还详细阐述了刻度尺、游标卡尺、螺旋测微器及打点计时器等常用测量工具的原理与误差控制技巧，帮助学生掌握科学实验的基本步骤。","summary":"本文系统梳理物理学史与实验测量方法，阐释量纲分析与核心理论的演进，涵盖古代哲学到现代实验工具的完整技术路线。","tags":["#物理学","#基础科学","#自然科学","#物理学史","#实验方法","#量纲分析","#牛顿力学","#电磁场理论","#量子假设","#相对论","#刻度尺","#游标卡尺","#螺旋测微器","#打点计时器","#实验设计","#高考复习","#大学物理","#科研方法","#教学培训","#高中生","#大学生"]},"task_lines":[],"tasks":{},"codeblock_ranges":[]},
