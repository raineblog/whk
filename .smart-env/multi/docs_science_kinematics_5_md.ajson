
"smart_sources:docs/science/kinematics/5.md": {"path":"docs/science/kinematics/5.md","last_embed":{"hash":null},"embeddings":{},"last_read":{"hash":"qu08yn","at":1774774481783},"class_name":"SmartSource","last_import":{"mtime":1774762570815,"size":1207,"at":1774774481812,"hash":"qu08yn"},"blocks":{"#---frontmatter---":[1,26],"#相对运动":[28,31],"#相对运动#{1}":[30,31]},"outlinks":[{"title":"alt text","target":"image-3.avif","line":30,"embedded":true}],"metadata":{"title":"相对运动详解：相对速度计算与实际应用场景全解析","description":"本文系统阐述相对运动的概念，从参考系转换出发，推导相对速度与相对加速度的计算公式，重点分析牛顿力学中的相对速度叠加原理与相对速度向量图示。随后讨论相对参考系在实验设计中的应用，包括相对速度测量、相对运动的可视化与相对速度在工程动力学、天体力学及相对论物理中的典型案例，帮助读者构建严谨的物理模型。","summary":"本文系统讲解相对运动的参考系转换、相对速度计算及其在物理实验与工程中的应用，帮助学生深入构建严谨的物理模型。","tags":["#高中物理","#经典力学","#相对运动","#参考系","#速度向量","#相对速度","#相对加速度","#速度叠加","#牛顿力学","#参考系转换","#相对速度计算","#相对参考系","#速度向量图示","#实验设计","#工程动力学","#天体力学","#相对论物理","#高考复习","#竞赛备考","#物理爱好者"]},"task_lines":[],"tasks":{},"codeblock_ranges":[]},
