
"smart_sources:docs/science/human/1.md": {"path":"docs/science/human/1.md","last_embed":{"hash":null},"embeddings":{},"last_read":{"hash":"196jfad","at":1774774481705},"class_name":"SmartSource","last_import":{"mtime":1774762570795,"size":1073,"at":1774774481781,"hash":"196jfad"},"blocks":{"#---frontmatter---":[1,21],"#运动系统":[23,26],"#运动系统#{1}":[25,26]},"outlinks":[],"metadata":{"title":"运动系统详解：生理学机制原理与康复医学应用场景","description":"本文系统阐述运动系统的解剖结构与生理学功能，重点分析肌肉收缩的滑动线机制、关节的力学原理及与神经系统、内分泌系统的协同调控。进一步探讨运动生物力学中的能量转换、代谢路径及运动对循环、呼吸系统的适应性响应，为高校体育与竞技训练提供科学依据","summary":"运动系统解剖结构肌肉收缩机制与生物力学能量转换探讨与神经循环等系统的协同作用为运动训练提供理论支撑支","tags":["#运动系统","#生理学","#肌肉收缩","#生物力学","#能量转换","#神经系统","#循环系统","#呼吸系统","#运动训练","#康复医学","#高校体育","#竞技训练","#解剖结构","#力学原理","#代谢路径"]},"task_lines":[],"tasks":{},"codeblock_ranges":[]},
