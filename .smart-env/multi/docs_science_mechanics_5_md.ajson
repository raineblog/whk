8,"embedded":true},{"title":"alt text","target":"m-image-14.avif","line":110,"embedded":true},{"title":"alt text","target":"m-image-13.avif","line":292,"embedded":true},{"title":"alt text","target":"m-image-7.avif","line":350,"embedded":true},{"title":"alt text","target":"m-image-8.avif","line":352,"embedded":true},{"title":"alt text","target":"m-image-1.avif","line":366,"embedded":true},{"title":"alt text","target":"m-image-10.avif","line":400,"embedded":true},{"title":"alt text","target":"image.avif","line":434,"embedded":true},{"title":"alt text","target":"m-image-2.avif","line":442,"embedded":true},{"title":"alt text","target":"m-image-12.avif","line":446,"embedded":true},{"title":"alt text","target":"e9057a15a2bbb76c_c2b0c7e.svg","line":504,"embedded":true},{"title":"alt text","target":"997a0e28b6108d82_6fa4db1-56c4028.avif","line":516,"embedded":true},{"title":"alt text","target":"786ede037f970bf8_e2317df.svg","line":518,"embedded":true},{"title":"alt text","target":"m-image-3.avif","line":564,"embedded":true},{"title":"alt text","target":"m-image-4.avif","line":578,"embedded":true},{"title":"alt text","target":"m-image-16.avif","line":649,"embedded":true},{"title":"alt text","target":"m-image-17.avif","line":657,"embedded":true},{"title":"alt text","target":"m-image-15.avif","line":713,"embedded":true}],"metadata":{"title":"机械振动详解：简谐运动机制与波的传播与应用","description":"本文系统阐释机械振动的基本概念与简谐运动的数学模型详细推导弹簧振子的回复力与角频率进一步探讨受迫振动与共振现象的发生条件进一步探讨驱动力对振幅的调制规律并扩展至机械波的定义波的要素衍射与干涉原理提供从理论推导到单摆测量重力的完整技术路线与实验示例并可用于竞赛复习科学知识库的构建与应用示范提升学习效率","summary":"本文系统解析机械振动的简谐运动、受迫振动与共振，阐明波的传播与衍射机制，提供从基础理论到实际测量的完整技术路线。","tags":["#机械振动","#简谐运动","#受迫振动","#共振","#波的传播","#波的衍射","#波的干涉","#弹簧振子","#单摆","#测重力","#高中物理","#大学物理","#波长","#频率","#振幅","#驱动力","#调谐质量阻尼器","#波动原理","#物理实验","#竞赛复习","#科学知识库"]},"task_lines":[],"tasks":{},"codeblock_ranges":[]},
