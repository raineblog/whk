的简谐运动、受迫振动与共振，阐明波的传播与衍射机制，提供从基础理论到实际测量的完整技术路线。","tags":["#机械振动","#简谐运动","#受迫振动","#共振","#波的传播","#波的衍射","#波的干涉","#弹簧振子","#单摆","#测重力","#高中物理","#大学物理","#波长","#频率","#振幅","#驱动力","#调谐质量阻尼器","#波动原理","#物理实验","#竞赛复习","#科学知识库"]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1iwgf9i","at":1774775305004}},"smart_blocks:docs/science/mechanics/5.md#---frontmatter---": {"path":null,"embeddings":{"Xenova/multilingual-e5-small":{"vec":[0.04511933,0.02421999,-0.05088494,-0.05078783,0.06319041,0.00347472,0.02023029,0.05589881,0.09251034,-0.02247421,0.01022933,-0.00603104,0.02956854,0.00840358,-0.04261152,0.05062003,0.03256863,-0.05353226,-0.0223932,-0.05658892,0.01752422,-0.00756453,-0.05691749,0.0269657,0.06542161,0.04258723,-0.04002516,0.01962907,0.04818033,-0.05120227,-0.04090297,-0.05962359,0.08356841,-0.05169726,0.03139653,0.03686391,-0.06195972,-0.05678407,0.07199291,-0.04668348,-0.004903,-0.00444508,0.04356912,0.08533626,0.03288975,0.0767274,-0.01968615,0.02115282,-0.051784,-0.03799144,-0.02116818,0.04514076,0.03542862,0.05462395,0.00076975,-0.05551642,-0.01363212,-0.05047696,-0.08812715,0.10577008,0.0762365,-0.02365905,0.01816321,0.06094148,0.08451527,0.03430574,0.05512178,-0.02383359,-0.02758589,-0.01644615,-0.06632603,0.08956583,0.03066667,-0.02804526,0.03181088,0.01123002,0.08743326,-0.05774285,0.03945709,-0.06118914,-0.07563156,-0.03423978,-0.04888614,-0.00699746,-0.07772865,0.05674694,0.08058675,-0.04867539,0.04696409,-0.0034399,0.06752059,0.03455203,-0.08063286,-0.05403641,-0.09779888,-0.058009,-0.02399962,0.00335097,0.07257038,0.02554203,0.11417149,-0.03105643,0.02326695,-0.10983138,-0.0578357,0.05316472,0.04243383,-0.06854662,0.0159155,-0.02332724,-0.03738455,0.02930755,0.07213076,0.05699822,-0.0756575,-0.0244291,0.0251936,-0.06422614,0.03965711,-0.04631723,0.05044758,-0.03178716,-0.03235392,-0.03167547,-0.0527655,-0.04931483,-0.00302065,0.0266428,0.00613092,0.01070216,0.05619168,0.08562592,-0.03472686,-0.00669703,0.02474418,0.08272529,-0.048746