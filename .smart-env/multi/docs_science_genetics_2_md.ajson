作用 $12:3:1$ 型#{1}":[460,467],"#孟德尔遗传规律#遗传规律中的特例#自由组合定律#相互抑制作用 $10:6$ 型":[468,477],"#孟德尔遗传规律#遗传规律中的特例#自由组合定律#相互抑制作用 $10:6$ 型#{1}":[470,477],"#孟德尔遗传规律#遗传规律中的特例#自由组合定律#相互抑制作用 $10:3:3$ 型":[478,487],"#孟德尔遗传规律#遗传规律中的特例#自由组合定律#相互抑制作用 $10:3:3$ 型#{1}":[480,487]},"outlinks":[{"title":"alt text","target":"image.avif","line":161,"embedded":true}],"metadata":{"title":"孟德尔遗传规律详解：分离与自由组合定律及应用场景","description":"本文系统阐述孟德尔遗传因子的分离定律与自由组合定律，解析配子形成过程、等位基因配对及表型-基因型关系，重点探讨豌豆杂交实验的统计方法、连续自交比例与致死配子模型，并提供白化病等遗传病的概率推断与育种策略。","summary":"本文深入解析孟德尔遗传因子的分离与自由组合规律，提供配子形成、自交比例及致死模型的统计推导，并阐释在育种与遗传病概率计算中的实际应用。","tags":["#孟德尔遗传规律","#高中生物","#分离定律","#自由组合定律","#配子形成","#等位基因","#表型-基因型","#自交比例","#致死配子","#统计比例","#育种策略","#遗传病概率","#实验设计","#竞赛复习","#理科竞赛","#基因型判断","#连续自交","#多因素遗传"]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1hl3xyp","at":1774775082221}},"smart_blocks:docs/science/genetics/2.md#---frontmatter---": {"path":null,"embeddings":{"Xenova/multilingual-e5-small":{"vec":[0.03020841,-0.03325105,-0.05003675,-0.02884326,0.06725279,-0.00482885,0.03928816,0.06860633,0.08649865,-0.02968519,0.02127368,-0.00719834,0.06759088,-0.03051753,-0.0318874,0.03192297,0.05849726,-0.0889511,0.0001309,-0.07185708,0.0028137,0.02709228,-0.04999802,0.03943063,0.101232,0.05333953,-0.03979483,0.02327995,0.09078877,-0.03207832,-0.03700393,-0.08686221,0.05846133,-0.06737632,0.07014048,0.03534046,-0.0563015,-0.03525253,0.04108237,-0.06132062,-0.02800551,0.02701978,0.07936377,0.05516547,0.03232912,0.04129335,-0.02661458,0.02225697,-0.02888961,-0.00848344,-0.00474549,0.06892194,0.03963819,0.03254182,0.00886158,-0.08057755,-0.03648936,-0.06219545,-0.07410651,0.09889902,0.05383127,-0.03447146,-0.02391244,0.10863432,0.06911868,0.03283572,0.03740007,0.01954533,-0.00604596,-0.01068151,-0.04916736,0.04348857,0.02093161,-0.01381451,0.00654991,-0.00422703,0.0551562,-0.02848336,0.0339446,-0.05041195,-0.06149214,-0.03930811,-0.05741204,0.00263435,-0.07266648,0.01531815,0.03080819,-0.03409308,0.03735015,-0.01144778,0