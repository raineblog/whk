
"smart_sources:docs/science/nature/1.md": {"path":"docs/science/nature/1.md","last_embed":{"hash":null},"embeddings":{},"last_read":{"hash":"15wc4lm","at":1774774481783},"class_name":"SmartSource","last_import":{"mtime":1774762570838,"size":1845,"at":1774774481812,"hash":"15wc4lm"},"blocks":{"#---frontmatter---":[1,26],"#自然地理":[28,75],"#自然地理#{1}":[30,31],"#自然地理#地球的运动":[32,39],"#自然地理#地球的运动#宇宙中的地球":[34,35],"#自然地理#地球的运动#地球的自转":[36,37],"#自然地理#地球的运动#地球的公转":[38,39],"#自然地理#地球表面形态":[40,47],"#自然地理#地球表面形态#地表形态与地貌":[42,43],"#自然地理#地球表面形态#岩石圈物质循环":[44,45],"#自然地理#地球表面形态#地表形态的变化":[46,47],"#自然地理#地球上的大气":[48,57],"#自然地理#地球上的大气#大气的组成":[50,51],"#自然地理#地球上的大气#大气的热力":[52,53],"#自然地理#地球上的大气#气压带与风带":[54,55],"#自然地理#地球上的大气#气候与天气系统":[56,57],"#自然地理#地球上的水":[58,67],"#自然地理#地球上的水#地球水循环":[60,61],"#自然地理#地球上的水#海水的性质":[62,63],"#自然地理#地球上的水#海水与陆地":[64,65],"#自然地理#地球上的水#海水与大气":[66,67],"#自然地理#植被与土壤":[68,75],"#自然地理#植被与土壤#地球上的植被":[70,71],"#自然地理#植被与土壤#地球上的土壤":[72,73],"#自然地理#植被与土壤#自然环境概述":[74,75]},"outlinks":[],"metadata":{"title":"自然地理详解：地球运动机制与空间分布应用概览","description":"本文系统阐述地球运动的自转、公转及其对气候带的影响，分析岩石圈物质循环与地表形态变化的动力学原理，进一步探讨大气组成、热力分布及气压带的形成机制，并详细解析地球水循环、海水性质及植被与土壤的相互作用，为自然地理的综合研究提供理论框架与实证依据。","summary":"系统解析地球自转、公转及大气、水循环等要素的物理机制，涵盖岩石圈循环与植被土壤的相互作用，为自然地理提供理论与应用框架。","tags":["#自然地理","#地球运动","#自转","#公转","#大气组成","#气压带","#水循环","#海水性质","#植被","#土壤","#岩石圈","#气候带","#环境研究","#生态管理","#自然资源","#科普教育","#高中生物","#大学地理","#科研方法","#理论框架"]},"task_lines":[],"tasks":{},"codeblock_ranges":[]},
