34],"#过渡元素概述#其他过渡元素":[335,408],"#过渡元素概述#其他过渡元素#高锰酸钾的还原产物":[337,408],"#过渡元素概述#其他过渡元素#高锰酸钾的还原产物#{1}":[339,408]},"outlinks":[],"metadata":{"title":"过渡元素概述详解：铁的氧化机理与工业应用与检验","description":"本文系统阐述铁的物理性质、化学反应及氧化物种类，重点分析铁与氧气、酸、水的反应机理，介绍铁盐与亚铁盐的溶解度差异、氧化还原行为及其在补铁剂中的应用，并说明高炉炼铁、实验检验及稀有金属的关键技术路线，文章还讨论了铁的氧化物分类、高炉炼铁流程、铁盐在酸碱条件下的水解与沉淀行为，以及补铁剂的无机、有机弱酸及螯合三代工艺，并涵盖KSCN检验、铁氰化物沉淀法等常用除杂手段。","summary":"铁的物理化学性质、氧化物分类、酸碱反应及补铁剂三代工艺全解析，涵盖实验检验与工业应用要点，适用于高中化学与大学材料课程学习与考试备考。","tags":["#无机化学","#材料科学","#高中化学","#大学化学","#过渡元素","#铁","#铁盐","#亚铁盐","#氧化物","#氢氧化物","#碳酸亚铁","#高铁酸","#补铁剂","#螯合","#KSCN检验","#铁氰化物","#高炉炼铁","#实验检验","#补铁剂制备","#杀菌净水","#稀有金属","#高中生","#大学生","#研究者","#医药工业"]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1qymmbu","at":1774774762846}},"smart_blocks:docs/science/element/fe.md#---frontmatter---": {"path":null,"embeddings":{"Xenova/multilingual-e5-small":{"vec":[0.04393816,-0.0024104,-0.06382321,-0.02987378,0.06126725,-0.00415111,-0.00276104,0.01064368,0.08032136,0.0095486,0.00627011,-0.01897702,0.0558618,0.01603744,-0.07718862,0.05655784,0.09033009,-0.07423696,-0.04803349,-0.04899265,0.01372853,0.00235987,-0.0600344,0.02725595,0.06191352,0.05323143,-0.07061408,0.05641913,0.05017414,-0.0770952,-0.00303657,-0.06356179,0.08084438,-0.02448655,0.06776162,0.0218655,-0.04866615,-0.06578904,0.02563523,-0.02714945,-0.03310392,0.00629845,0.04926789,0.0783473,0.04359962,0.05774646,-0.03533056,-0.00606283,-0.02090835,-0.0283171,-0.02714005,-0.00105585,0.0195177,0.05860104,0.02770514,-0.04028115,-0.02890427,-0.03583126,-0.0835799,0.08015198,0.07962318,-0.01401581,0.02079128,0.03587242,0.0772263,0.03401189,0.06861221,-0.0193226,-0.03756014,-0.02453574,-0.00916134,0.06736892,-0.01194959,-0.02820962,0.0109121,0.01868117,0.07543144,-0.04966743,0.02376443,-0.06670316,-0.09764332,-0.04621837,-0.05733629,-0.02385699,-0.06406913,0.03744562,0.02757532,-0.0935355,0.06593354,-0.02546532,0.04706252,0.04693798,-0.02525582,-0.03117358,-0.08439665,-0.0591093,-0.03089023,0.06315573,0.0550706