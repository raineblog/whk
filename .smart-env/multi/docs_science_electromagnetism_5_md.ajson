bedded":true},{"title":"alt text","target":"image-25.avif","line":88,"embedded":true},{"title":"alt text","target":"image-41.avif","line":100,"embedded":true},{"title":"alt text","target":"image-26.avif","line":142,"embedded":true},{"title":"alt text","target":"image-39.avif","line":176,"embedded":true},{"title":"alt text","target":"image-27.avif","line":186,"embedded":true},{"title":"alt text","target":"image-42.avif","line":216,"embedded":true},{"title":"alt text","target":"image-43.avif","line":232,"embedded":true},{"title":"alt text","target":"image-44.avif","line":234,"embedded":true},{"title":"alt text","target":"image-40.avif","line":387,"embedded":true},{"title":"alt text","target":"image-4x.avif","line":414,"embedded":true}],"metadata":{"title":"电磁感应详解：磁通量与楞次定律在实验中的应用与实践","description":"本文深入解析电磁感应的完整技术路线，从磁通量的几何定义出发，推导安培环路定律与楞次定律，阐明感生电动势与动生电动势的产生机制，进一步探讨自感、互感、涡流及其在变压器、电机、探测器中的应用实例。通过公式展示磁场变化与感应电动势的定量关系，并分析能量转化与电磁阻尼的物理意义，为学生提供系统的理论框架与实验思路。","summary":"系统阐述电磁感应核心概念，涵盖磁通量、安培定律、楞次定律及感生、动生电动势，并分析自感、互感、涡流在电机、变压器中的应用。","tags":["#高中物理","#大学物理","#理综","#电磁感应","#磁通量","#感应电动势","#自感","#互感","#楞次定律","#安培环路","#涡流","#动生电动势","#感生电动势","#电感","#实验设计","#竞赛复习","#工业应用","#能量转化","#电磁阻尼","#高考复习","#理工科学生","#STEM教育"]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"zqfrfa","at":1774778450588},"key":"docs/science/electromagnetism/5.md"},
