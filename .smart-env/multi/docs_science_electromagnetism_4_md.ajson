},{"title":"alt text","target":"image-8.avif","line":99,"embedded":true},{"title":"alt text","target":"image-22.avif","line":109,"embedded":true},{"title":"alt text","target":"image.avif","line":165,"embedded":true},{"title":"alt text","target":"image-1.avif","line":175,"embedded":true},{"title":"alt text","target":"image-2.avif","line":189,"embedded":true},{"title":"alt text","target":"image-3.avif","line":197,"embedded":true},{"title":"alt text","target":"image-4.avif","line":211,"embedded":true},{"title":"alt text","target":"image-5.avif","line":225,"embedded":true},{"title":"alt text","target":"image-6.avif","line":233,"embedded":true},{"title":"alt text","target":"image-9.avif","line":249,"embedded":true},{"title":"alt text","target":"image-30.avif","line":259,"embedded":true},{"title":"alt text","target":"image-28.avif","line":267,"embedded":true},{"title":"alt text","target":"shapes at 25-07-23 19.13.09.svg","line":400,"embedded":true},{"title":"alt text","target":"image-12.avif","line":418,"embedded":true},{"title":"alt text","target":"image-34.avif","line":432,"embedded":true},{"title":"alt text","target":"image-33.avif","line":483,"embedded":true},{"title":"alt text","target":"image-35.avif","line":485,"embedded":true},{"title":"alt text","target":"./20251017202756.avif","line":507,"embedded":true},{"title":"alt text","target":"image-36.avif","line":521,"embedded":true},{"title":"alt text","target":"image-11.avif","line":529,"embedded":true},{"title":"alt text","target":"image-37.avif","line":553,"embedded":true},{"title":"alt text","target":"image-13.avif","line":563,"embedded":true},{"title":"alt text","target":"image-14.avif","line":579,"embedded":true},{"title":"alt text","target":"image-15.avif","line":597,"embedded":true},{"title":"alt text","target":"image-38.avif","line":599,"embedded":true},{"title":"alt text","target":"image-16.avif","line":653,"embedded":true},{"title":"alt text","target":"image-17.avif","line":657,"embedded":true},{"title":"alt text","target":"image-23.avif","line":661,"embedded":true},{"title":"alt text","target":"image-21.avif","line":673,"embedded":true},{"title":"alt text","target":"image-19.avif","line":687,"embedded":true},{"title":"alt text","target":"image-20.avif","line":697,"embedded":true},{"title":"alt text","target":"image-29.avif","line":701,"embedded":true}],"metadata":{"title":"磁场详解磁感应原理洛伦兹力机制与实际应用场景","description":"本文系统阐释磁场概念包括磁极特性地磁偏角及安培分子环流假说进一步解释磁感应强度定义洛伦兹力公式及其在粒子运动中的应用详细描述软硬磁材料的磁化过程应用场景以及磁场在粒子加速磁聚焦与回旋加速器中的典型实验以及这些技术在通信医疗成像与核能研究中的关键作用","summary":"详细解释磁场基本特性、磁感应原理及其在软硬磁材料、粒子加速与磁聚焦中的应用，涵盖实验原理与技术实现。","tags":["#磁场","#磁感应","#洛伦兹力","#安培定律","#软磁材料","#硬磁材料","#粒子加速","#磁聚焦","#回旋加速器","#霍尔效应","#电磁实验","#物理学","#高中物理","#大学物理","#实验室演示","#技术应用","#科学原理","#磁场线","#磁极","#磁场强度","#磁通密度"]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"vloank","at":1774778068554}},"smart_blocks:docs/science/electromagnetism/4.md#---frontmatter---": {"path":null,"embeddings":{"Xenova/multilingual-e5-small":{"vec":[0.07005961,-0.01591005,-0.05696569,-0.05888616,0.08955702,-0.01110718,0.05478697,0.0602832,0.10047791,-0.05346196,0.00975122,-0.0441247,0.04320666,0.00792326,-0.03407814,0.06278579,0.09659784,-0.05085261,-0.02629855,-0.04866098,0.03032216,-0.0118857,-0.07166635,0.04372366,0.05206262,0.03467771,-0.04964625,0.02251694,0.06040626,-0.04769053,-0.03539675,-0.06734107,0.09853769,-0.02327611,0.05569262,0.0177506,-0.0962832,-0.02475744,0.03846037,-0.05364656,-0.00264247,-0.0315864,0.04702873,0.1095952,0.02886145,0.09745383,-0.04457824,0.01382103,-0.02750569,-0.02986482,-0.05121676,0.0724953,0.01450024,0.03409541,-0.00167207,-0.04962053,-0.0237222,-0.05856416,-0.06251957,0.07113051,0.07688519,-0.03950826,0.01453155,0.04703388,0.08920651,0.0712696,0.03334902,0.0275924,-0.01097957,-0.02973286,-0.06137773,0.08024359,-0.00581815,-0.06183269,-0.00719079,0.00226751,0.06088662,-0.03395433,0.05244568,-0.03340085,-0.07877601,-0.00226563,-0.01973953,-0.01814471,-0.06775332,0.03097855,0.04092961,