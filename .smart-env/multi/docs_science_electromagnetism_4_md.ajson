":"image-13.avif","line":563,"embedded":true},{"title":"alt text","target":"image-14.avif","line":579,"embedded":true},{"title":"alt text","target":"image-15.avif","line":597,"embedded":true},{"title":"alt text","target":"image-38.avif","line":599,"embedded":true},{"title":"alt text","target":"image-16.avif","line":653,"embedded":true},{"title":"alt text","target":"image-17.avif","line":657,"embedded":true},{"title":"alt text","target":"image-23.avif","line":661,"embedded":true},{"title":"alt text","target":"image-21.avif","line":673,"embedded":true},{"title":"alt text","target":"image-19.avif","line":687,"embedded":true},{"title":"alt text","target":"image-20.avif","line":697,"embedded":true},{"title":"alt text","target":"image-29.avif","line":701,"embedded":true}],"metadata":{"title":"磁场详解磁感应原理洛伦兹力机制与实际应用场景","description":"本文系统阐释磁场概念包括磁极特性地磁偏角及安培分子环流假说进一步解释磁感应强度定义洛伦兹力公式及其在粒子运动中的应用详细描述软硬磁材料的磁化过程应用场景以及磁场在粒子加速磁聚焦与回旋加速器中的典型实验以及这些技术在通信医疗成像与核能研究中的关键作用","summary":"详细解释磁场基本特性、磁感应原理及其在软硬磁材料、粒子加速与磁聚焦中的应用，涵盖实验原理与技术实现。","tags":["#磁场","#磁感应","#洛伦兹力","#安培定律","#软磁材料","#硬磁材料","#粒子加速","#磁聚焦","#回旋加速器","#霍尔效应","#电磁实验","#物理学","#高中物理","#大学物理","#实验室演示","#技术应用","#科学原理","#磁场线","#磁极","#磁场强度","#磁通密度"]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"13d1cma","at":1774778442159}},"smart_blocks:docs/science/electromagnetism/4.md#---frontmatter---": {"path":null,"embeddings":{"Xenova/multilingual-e5-small":{"vec":[0.06983159,-0.0159078,-0.05662092,-0.0580125,0.08992949,-0.01095553,0.05438308,0.06045746,0.09958676,-0.054026,0.01038799,-0.04424359,0.04296246,0.00825856,-0.03458342,0.06239668,0.09640976,-0.05071388,-0.02616354,-0.0480333,0.02978723,-0.01214652,-0.07184239,0.04346099,0.05200987,0.03408331,-0.0499011,0.02342967,0.06080689,-0.04803927,-0.03569017,-0.06659257,0.0988355,-0.02350269,0.05603526,0.01730894,-0.0958795,-0.02476923,0.03809197,-0.0533427,-0.00396857,-0.03191064,0.04678976,0.10992505,0.02956828,0.09704551,-0.04548167,0.0134822,-0.0288833,-0.03025266,-0