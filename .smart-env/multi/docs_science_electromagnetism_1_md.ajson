:117,"embedded":true},{"title":"alt text","target":"fimage-5.avif","line":131,"embedded":true},{"title":"alt text","target":"image.avif","line":235,"embedded":true},{"title":"摩擦生电","target":"摩擦生电.avif","line":267,"embedded":true},{"title":"感应起电","target":"Electroscope_showing_induction.avif","line":288,"embedded":true},{"title":"空球壳模型","target":"空球壳模型.svg","line":339,"embedded":true},{"title":"静电屏蔽","target":"静电屏蔽.svg","line":355,"embedded":true},{"title":"alt text","target":"fimage-6.avif","line":374,"embedded":true},{"title":"alt text","target":"fimage-4.avif","line":458,"embedded":true}],"metadata":{"title":"静电力学详解：库仑定律机制及实际应用于电子器件","description":"本文系统阐述静电力学中的电荷特性、守恒定律及量子化，重点解析库仑定律的基本形式、介电常数的影响以及带电金属球的感应力学。进一步讨论三点一线平衡、等边三角平衡及原子核尺度的库仑与万有引力比较，最后涵盖摩擦、接触与感应起电的实验原理及静电屏蔽、除尘等实际应用。","summary":"本文系统解析静电力学的基本概念、库仑定律及其在电子器件中的应用，涵盖电荷守恒、感应起电与静电屏蔽等关键技术，在高频电路中的角色。","tags":["#静电力学","#高中物理","#大学物理","#电荷","#电荷守恒","#库仑定律","#介电常数","#感应起电","#静电屏蔽","#电子器件","#半导体","#等离子体","#实验原理","#竞赛复习","#物理公式","#物理现象","#物理概念","#物理应用","#物理实验","#物理知识","#物理教学"]},"task_lines":[],"tasks":{},"codeblock_ranges":[]},
