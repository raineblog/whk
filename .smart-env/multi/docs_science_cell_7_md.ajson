ology/%E5%8F%91%E9%85%B5%E5%B7%A5%E7%A8%8B%E8%8B%8F%E6%95%99%E7%89%88%E8%A1%A5%E5%85%85%E8%B5%84%E6%96%99.pdf","line":303},{"title":"alt text","target":"image-3-3bd915d.avif","line":342,"embedded":true},{"title":"alt text","target":"image-4-0828eca.avif","line":499,"embedded":true},{"title":"alt text","target":"image-5-e99d938.avif","line":503,"embedded":true},{"title":"alt text","target":"image-30-2c9d08c.avif","line":587,"embedded":true},{"title":"alt text","target":"image-55-4a5b24b.avif","line":693,"embedded":true},{"title":"发酵罐结构及工艺控制示意图","target":"image-7-b551253.avif","line":705,"embedded":true},{"title":"alt text","target":"image-8-fe78203.avif","line":785,"embedded":true},{"title":"alt text","target":"image-54-298bc5d.avif","line":835,"embedded":true},{"title":"alt text","target":"image-66-f6ddba4.avif","line":842,"embedded":true},{"title":"alt text","target":"image-c6a3cbf.avif","line":860,"embedded":true},{"title":"聚乳酸循环应用示意图","target":"image-9-fb7a535.avif","line":900,"embedded":true},{"title":"alt text","target":"image-29-bc53fb4.avif","line":1021,"embedded":true}],"metadata":{"title":"发酵技术详解：酵母发酵机制与工业应用微生物工程","description":"本文系统阐述发酵技术的三大定义及其演进重点解析酵母菌酒精发酵乳酸菌乳酸发酵以及醋酸菌氧化乙醇的生化路径通过分子水平描述糖酵解丙酮酸还原及氧化磷酸化过程详细说明在厌氧与好氧条件下NAD再生酶活性调控及代谢通量分配并对工业规模化操作中的温度pH溶解氧控制提供深度解析","summary":"发酵技术全景解析从微生物定义到工业规模化操作重点阐述酵母乳酸菌醋酸菌的代谢机制与应用在食品医药农业等领域的广泛应用","tags":["#生物化学","#微生物学","#发酵工程","#酵母","#乳酸菌","#醋酸菌","#NAD再生","#酶活性","#糖酵解","#代谢通量","#食品工业","#医药生产","#农牧业","#培养基","#微生物纯培养","#发酵罐","#无菌技术","#pH控制","#溶解氧","#工业规模化"]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"w3ozzu","at":1774774935266}},"smart_blocks:docs/science/cell/7.md#---frontmatter---": {"path":null,"embeddings":{"Xenova/multilingual-e5-small":{"vec":[0.06596027,0.01324135,-0.04474479,-0.05130793,0.11939093,-0.00166425,0.02233501,0.07750823,0.07918001,0.02127266,0.00583599,-0.05245341,0.0671876,-0.01140246,-0.06451467,0.04986282,0.0790564,-0.06063448,-0.02787228,-0.04053283,0.0537773,0.02370653,-0.058