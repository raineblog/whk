合竞赛与数学学习","tags":["#组合数学","#高中数学","#离散数学","#计数原理","#加法原理","#乘法原理","#减法原理","#除法原理","#排列数","#组合数","#二项式定理","#杨辉三角","#因数个数","#子集个数","#竞赛备考","#高考复习","#大学数学","#理科生","#数学竞赛"]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"e4zntp","at":1774778481613},"key":"docs/science/probability/3.md"},
