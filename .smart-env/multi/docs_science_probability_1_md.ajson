22],"#概率与随机#概率的应用#分布的深入理解#{1}":[469,522],"#概率与随机#概率的应用#生日悖论与密码学":[523,526],"#概率与随机#概率的应用#生日悖论与密码学#{1}":[525,526],"#概率与随机#概率的应用#信息熵":[527,546],"#概率与随机#概率的应用#信息熵#{1}":[529,546]},"outlinks":[{"title":"Prob-Stat","target":"http://staff.ustc.edu.cn/~zwp/teach/Prob-Stat/probstat.htm","line":30},{"title":"讲义","target":"https://huggingface.co/datasets/RainPPR/whk/resolve/main/math/%E6%A6%82%E7%8E%87%E8%AE%BA%E4%B8%8E%E6%95%B0%E7%90%86%E7%BB%9F%E8%AE%A1%E8%AE%B2%E4%B9%89.pdf","line":30},{"title":"课件","target":"https://huggingface.co/datasets/RainPPR/whk/resolve/main/math/USTC_Prob_Stat_Complete.pdf","line":30},{"title":"**OI Wiki**","target":"https://oi-wiki.org/","line":32},{"title":"Bertrand（伯特兰）悖论","target":"https://en.wikipedia.org/wiki/Bertrand_paradox_(probability","line":220},{"title":"Wikipedia","target":"https://en.wikipedia.org/wiki/Positive_and_negative_predictive_values","line":465}],"metadata":{"title":"概率与随机详解：样本空间构成与大数定律应用","description":"本文系统阐释概率论基础概念，包括样本空间、随机事件、互斥与对立、独立性及大数定律，进一步推导条件概率、全概率公式与贝叶斯定理，解释随机变量的离散与连续类型，并涉及示性函数、概率分布、马尔可夫不等式及其在统计推断、竞赛复习与信息熵中的应用。","summary":"本文系统梳理概率论核心概念，涵盖样本空间、事件关系、大数定律与独立性，并深入阐释条件概率、随机变量及其在统计与竞赛中的应用。","tags":["#高中数学","#概率论","#统计学","#样本空间","#随机事件","#互斥事件","#对立事件","#独立事件","#大数定律","#条件概率","#全概率公式","#贝叶斯定理","#示性函数","#离散型随机变量","#连续型随机变量","#马尔可夫不等式","#竞赛复习","#统计推断","#信息熵","#高考数学"]},"task_lines":[],"tasks":{},"codeblock_ranges":[]},
