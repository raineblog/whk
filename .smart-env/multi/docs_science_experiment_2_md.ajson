
"smart_sources:docs/science/experiment/2.md": {"path":"docs/science/experiment/2.md","last_embed":{"hash":null},"embeddings":{},"last_read":{"hash":"u1288n","at":1774774481665},"class_name":"SmartSource","last_import":{"mtime":1774762570765,"size":6040,"at":1774774481703,"hash":"u1288n"},"blocks":{"#---frontmatter---":[1,26],"#化学实验仪器":[28,131],"#化学实验仪器#{1}":[30,33],"#化学实验仪器#现场救护原则":[34,43],"#化学实验仪器#现场救护原则#{1}":[37,43],"#化学实验仪器#测量仪器类":[44,73],"#化学实验仪器#测量仪器类#托盘天平":[46,53],"#化学实验仪器#测量仪器类#托盘天平#{1}":[48,53],"#化学实验仪器#测量仪器类#量筒":[54,61],"#化学实验仪器#测量仪器类#量筒#{1}":[56,61],"#化学实验仪器#测量仪器类#容量瓶":[62,73],"#化学实验仪器#测量仪器类#容量瓶#{1}":[64,73],"#化学实验仪器#加热仪器类":[74,97],"#化学实验仪器#加热仪器类#加热概述":[76,89],"#化学实验仪器#加热仪器类#加热概述#{1}":[78,89],"#化学实验仪器#加热仪器类#酒精灯和酒精喷灯":[90,97],"#化学实验仪器#加热仪器类#酒精灯和酒精喷灯#{1}":[92,97],"#化学实验仪器#冷却与冷凝仪器类":[98,107],"#化学实验仪器#冷却与冷凝仪器类#{1}":[100,107],"#化学实验仪器#反应容器与存放类":[108,121],"#化学实验仪器#反应容器与存放类#{1}":[110,121],"#化学实验仪器#辅助仪器类":[122,131],"#化学实验仪器#辅助仪器类#{1}":[124,131]},"outlinks":[],"metadata":{"title":"化学实验仪器详解：测量加热冷凝的原理与应用场景","description":"本文系统介绍化学实验室常用仪器的分类与使用要点，涵盖现场救护的先抢后救、先检后送等原则，详述托盘天平、量筒、容量瓶的读取与使用限制，阐释浴加热、酒精灯加热及其适用温度范围，并解析直形、球形、蛇形冷凝管的安装与冷凝原理，进一步说明试管、烧瓶、集气瓶等容器的适用场景与储存注意事项，辅以玻璃棒、胶头滴管等辅助工具的正确操作方法。","summary":"本文系统讲解化学实验仪器的分类、使用要点及安全操作原则，涵盖测量、加热、冷凝及储存全流程，适合实验室学习与实践。","tags":["#高中化学","#大学化学","#实验室仪器","#化学实验仪器","#托盘天平","#量筒","#容量瓶","#浴加热","#酒精灯","#冷凝管","#试管","#烧瓶","#集气瓶","#实验安全","#实验操作","#实验设计","#课堂教学","#竞赛复习","#学生实验","#实验室管理"]},"task_lines":[],"tasks":{},"codeblock_ranges":[]},
