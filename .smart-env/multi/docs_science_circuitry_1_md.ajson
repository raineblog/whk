arget":"1.avif","line":178,"embedded":true},{"title":"image","target":"2.avif","line":178,"embedded":true},{"title":"image","target":"3.avif","line":179,"embedded":true},{"title":"image","target":"4.avif","line":179,"embedded":true},{"title":"image","target":"5.avif","line":180,"embedded":true},{"title":"image","target":"6.avif","line":180,"embedded":true},{"title":"alt text","target":"image-6.avif","line":288,"embedded":true},{"title":"image","target":"8.avif","line":371,"embedded":true},{"title":"image","target":"7.avif","line":391,"embedded":true},{"title":"alt text","target":"image-7.avif","line":414,"embedded":true},{"title":"alt text","target":"image-8.avif","line":416,"embedded":true},{"title":"image","target":"kl1.avif","line":458,"embedded":true},{"title":"image","target":"kl2.avif","line":474,"embedded":true},{"title":"image","target":"kcl.avif","line":524,"embedded":true},{"title":"image","target":"kvl.avif","line":546,"embedded":true},{"title":"alt text","target":"image-1.avif","line":614,"embedded":true},{"title":"alt text","target":"image-5.avif","line":626,"embedded":true},{"title":"alt text","target":"image-14.avif","line":640,"embedded":true},{"title":"alt text","target":"image-15.avif","line":648,"embedded":true},{"title":"alt text","target":"image-16.avif","line":664,"embedded":true},{"title":"alt text","target":"image-17.avif","line":674,"embedded":true},{"title":"alt text","target":"image-18.avif","line":726,"embedded":true},{"title":"alt text","target":"image-21.avif","line":776,"embedded":true},{"title":"alt text","target":"image-19.avif","line":782,"embedded":true},{"title":"alt text","target":"image-20.avif","line":803,"embedded":true}],"metadata":{"title":"恒定电流详解：电流定义与欧姆定律及应用场景","description":"本文系统阐述恒定电流的定义、微观运动速率及其统计意义，推导电流公式 I=e/T，并解释欧姆定律的线性适用范围、电阻与温度的关系，进一步推导电阻率公式 R=ρl/S，阐明焦耳加热 Q=I²Rt，最后通过电源内阻、串并联规律及基尔霍夫定律求解复杂电路中的电流分布与功率分配。同时说明在无穷电路与对称简化中的等效电阻计算方法，以及通过叠加定理和基尔霍夫定律求解实际例题的步骤与结果。","summary":"恒定电流的定义、微观运动及统计意义，推导电流公式 I=e/T，阐释欧姆定律线性适用范围，并通过电源内阻与基尔霍夫定律求解复杂电路电流与功率。","tags":["#高中物理","#恒定电流","#电流定义","#微观速率","#欧姆定律","#电阻率","#焦耳加热","#电源内阻","#串并联","#基尔霍夫定律","#叠加定理","#无穷电路","#对称简化","#电路分析","#功率计算","#电流表","#竞赛备考","#实验设计"]},"task_lines":[],"tasks":{},"codeblock_ranges":[]},
