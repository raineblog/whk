
"smart_sources:docs/science/mechanics/7.md": {"path":"docs/science/mechanics/7.md","last_embed":{"hash":null},"embeddings":{},"last_read":{"hash":"19bufqb","at":1774774481813},"class_name":"SmartSource","last_import":{"mtime":1774762570830,"size":5259,"at":1774774481932,"hash":"19bufqb"},"blocks":{"#---frontmatter---":[1,24],"#转动角动量":[26,159],"#转动角动量#基本概念":[28,85],"#转动角动量#基本概念#角动量":[30,53],"#转动角动量#基本概念#角动量#{1}":[32,53],"#转动角动量#基本概念#角动量定理":[54,79],"#转动角动量#基本概念#角动量定理#{1}":[56,79],"#转动角动量#基本概念#角动量守恒":[80,85],"#转动角动量#基本概念#角动量守恒#{1}":[82,85],"#转动角动量#力矩和力偶":[86,159],"#转动角动量#力矩和力偶#力矩":[88,121],"#转动角动量#力矩和力偶#力矩#{1}":[90,121],"#转动角动量#力矩和力偶#力偶":[122,145],"#转动角动量#力矩和力偶#力偶#{1}":[124,145],"#转动角动量#力矩和力偶#定轴平衡":[146,153],"#转动角动量#力矩和力偶#定轴平衡#{1}":[148,153],"#转动角动量#力矩和力偶#一般物体平衡":[154,159],"#转动角动量#力矩和力偶#一般物体平衡#{1}":[156,159]},"outlinks":[],"metadata":{"title":"转动角动量详解：力矩机制与守恒应用场景原理与实例","description":"本文系统阐释转动角动量的基本概念，包括角动量的向量表达、定理推导及守恒条件，重点分析力矩的定义、分量及其与力偶的关系，并通过典型例子展示在天体运动与转轴平衡中的应用，适合理综学习与竞赛复习。文中进一步推导角动量守恒的条件，说明在无外力矩作用下系统角动量守恒，并解释在绕轴转动、天体公转及实验测量中的实际意义，帮助学生构建完整的力学框架。","summary":"本文系统解析转动角动量概念、力矩定理及守恒条件，阐明在天体运动与转轴平衡中的应用，帮助构建完整力学框架。","tags":["#高中物理","#转动角动量","#角动量","#力矩","#守恒","#角动量定理","#力偶","#定轴平衡","#天体运动","#实验测量","#竞赛复习","#理综学习","#高考生","#大学物理","#力的分解","#向量叉积","#力矩大小","#物理力学"]},"task_lines":[],"tasks":{},"codeblock_ranges":[]},
