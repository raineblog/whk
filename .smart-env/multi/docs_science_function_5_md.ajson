149,173],"#微积分#积分#微积分基本定理 / $\\mathrm{Newton-Leibniz}$ 牛顿 - 莱布尼兹公式#应用#{1}":[151,152],"#微积分#积分#微积分基本定理 / $\\mathrm{Newton-Leibniz}$ 牛顿 - 莱布尼兹公式#应用#{2}":[153,154],"#微积分#积分#微积分基本定理 / $\\mathrm{Newton-Leibniz}$ 牛顿 - 莱布尼兹公式#应用#{3}":[155,156],"#微积分#积分#微积分基本定理 / $\\mathrm{Newton-Leibniz}$ 牛顿 - 莱布尼兹公式#应用#{4}":[157,158],"#微积分#积分#微积分基本定理 / $\\mathrm{Newton-Leibniz}$ 牛顿 - 莱布尼兹公式#应用#{5}":[159,159],"#微积分#积分#微积分基本定理 / $\\mathrm{Newton-Leibniz}$ 牛顿 - 莱布尼兹公式#应用#{6}":[160,173],"#微积分#微积分在数列中的应用":[174,309],"#微积分#微积分在数列中的应用#{1}":[176,273],"#微积分#微积分在数列中的应用#积分放缩在数列中的应用":[274,309],"#微积分#微积分在数列中的应用#积分放缩在数列中的应用#{1}":[276,309]},"outlinks":[{"title":"alt text","target":"image-6.avif","line":28,"embedded":true},{"title":"a,b","target":"a\\neq b","line":34},{"title":"知乎专栏","target":"https://zhuanlan.zhihu.com/p/144278965","line":256}],"metadata":{"title":"微积分详解：几何意义、基本定理与典型案例深入解析","description":"本文系统阐述定积分的几何意义、正负面积的代数处理，并深入推导微积分基本定理及其不定积分形式。重点解析换元法、分部积分法的操作步骤，涵盖常用积分公式、伽马函数及其递推关系，并通过典型案例展示在数列求极限、面积计算及参数求极值中的应用。","summary":"本文系统解析定积分的几何意义与基本定理，详述换元、分部积分法，涵盖伽马函数与典型应用，帮助掌握积分在数列与面积计算中的运用。","tags":["#微积分","#积分","#换元法","#分部积分","#原函数","#几何意义","#伽马函数","#递推关系","#面积计算","#数列极限","#参数极值","#数学建模","#大学数学","#自学者","#竞赛备考","#基本定理","#不定积分","#定积分"]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1e8zudv","at":1774775864334},"key":"docs/science/function/5.md"},
