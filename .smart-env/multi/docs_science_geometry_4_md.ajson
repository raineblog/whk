}":[840,853],"#解析几何#拓展定理#相交弦定理":[854,867],"#解析几何#拓展定理#相交弦定理#{1}":[856,867],"#解析几何#拓展定理#圆幂定理":[868,989],"#解析几何#拓展定理#圆幂定理#{1}":[870,989],"#解析几何#拓展定理#西姆松定理":[990,1007],"#解析几何#拓展定理#西姆松定理#{1}":[992,1007],"#解析几何#拓展定理#定点速求":[1008,1125],"#解析几何#拓展定理#定点速求#{1}":[1010,1125]},"outlinks":[{"title":"alt text","target":"image-15.avif","line":58,"embedded":true},{"title":"alt text","target":"Superellipse-3.avif","line":402,"embedded":true},{"title":"alt text","target":"image-1.avif","line":415,"embedded":true},{"title":"alt text","target":"Construction_triangle_Reuleaux[1].svg","line":423,"embedded":true},{"title":"alt text","target":"image.avif","line":425,"embedded":true},{"title":"alt text","target":"Reinhardt_15-gons[1].svg","line":431,"embedded":true},{"title":"圆锥曲线Fregier定理：定点与定斜率和积 - 知乎","target":"https://zhuanlan.zhihu.com/p/1971264129353384768","line":834},{"title":"定点之Fregier定理 - 知乎","target":"https://zhuanlan.zhihu.com/p/673855234","line":834},{"title":"alt text","target":"reconstructed_image.svg","line":858,"embedded":true},{"title":"alt text","target":"Potenzgeome_86e68c8.svg","line":880,"embedded":true},{"title":"alt text","target":"Potenzseksehnee_a196a35.svg","line":882,"embedded":true},{"title":"Power of a point - Wikipedia","target":"https://en.wikipedia.org/wiki/Power_of_a_point","line":940},{"title":"Similarity points, common power of two circles - Power of a point - Wikipedia","target":"https://en.wikipedia.org/wiki/Power_of_a_point#Similarity_points,_common_power_of_two_circles","line":988},{"title":"alt text","target":"image-21.avif","line":996,"embedded":true},{"title":"alt text","target":"image-23.avif","line":998,"embedded":true}],"metadata":{"title":"圆锥截线详解：离心率机制与天体轨道应用场景","description":"本文系统阐释圆锥截线的几何定义、离心率公式 e=cosβ/cosα 以及不同切角对应的椭圆、抛物线、双曲线类型。随后介绍二次曲线的一般方程、矩阵判别条件 Δ2、Δ3，推导标准方程、焦点及离心率统一公式，并结合天体运动中的轨迹分类，提供从纯几何到坐标代数的完整解析路线。","summary":"全面解析圆锥截线的离心率机制、几何分类及天体轨道应用，提供标准方程推导、矩阵判别与焦点坐标计算方法。并阐释坐标变换与焦点位置计算","tags":["#高中几何","#大学空间几何","#天体力学","#圆锥截线","#离心率","#椭圆","#双曲线","#抛物线","#焦点","#离心率公式","#Δ2","#Δ3","#矩阵判别","#天体轨道","#实验设计","#高考复习","#竞赛备考","#理综学习"]},"task_lines":[],"tasks":{},"codeblock_ranges":[[536,550],[552,577],[778,802],[1044,1087],[1089,1124]],"last_embed":{"hash":"1sqwz0b","at":1775649303010},"key":"docs/science/geometry/4.md"},
