应#{1}":[613,626],"#有机反应记忆#按要求完成下列各题#常见有机反应的反应条件#2. 苯的取代反应":[627,642],"#有机反应记忆#按要求完成下列各题#常见有机反应的反应条件#2. 苯的取代反应#{1}":[629,642],"#有机反应记忆#按要求完成下列各题#常见有机反应的反应条件#3. 醛的氧化反应":[643,660],"#有机反应记忆#按要求完成下列各题#常见有机反应的反应条件#3. 醛的氧化反应#{1}":[645,660],"#有机反应记忆#按要求完成下列各题#常见有机反应的反应条件#4. 酯化反应与水解反应":[661,678],"#有机反应记忆#按要求完成下列各题#常见有机反应的反应条件#4. 酯化反应与水解反应#{1}":[663,678],"#有机反应记忆#按要求完成下列各题#常见有机反应的反应条件#5. 酚醛树脂的制备":[679,694],"#有机反应记忆#按要求完成下列各题#常见有机反应的反应条件#5. 酚醛树脂的制备#{1}":[681,694],"#有机反应记忆#按要求完成下列各题#常见有机反应的反应条件#6. 其他常见反应":[695,716],"#有机反应记忆#按要求完成下列各题#常见有机反应的反应条件#6. 其他常见反应#{1}":[697,716],"#有机反应记忆#按要求完成下列各题#常见有机反应的反应条件#反应条件总结表":[717,728],"#有机反应记忆#按要求完成下列各题#常见有机反应的反应条件#反应条件总结表#{1}":[719,728]},"outlinks":[],"metadata":{"title":"烃的反应详解：氧化、取代与加成机理与应用场景","description":"本文系统阐述烃类的结构特征与反应路线，涵盖烷烃的氧化燃烧、取代反应及自由基机理；烯烃的脱氢、加成与聚合过程，详细分析电子富集与过渡态；炔烃的氧化与加成反应原理；苯及其衍生物的取代与氧化行为；并探讨气态烃燃烧后分子数守恒的条件，提供实验设计与高考复习的实用框架。","summary":"系统解析烃类结构与反应机理，涵盖氧化、取代、加成及聚合过程，并探讨燃烧分子数守恒条件，适用于高中与大学化学复习。","tags":["#烃","#烷烃","#烯烃","#炔烃","#苯","#甲苯","#氧化反应","#取代反应","#加成反应","#加聚反应","#燃烧","#气态烃","#分子数守恒","#实验设计","#高考复习","#竞赛备考","#化工原料","#大学有机化学","#高中化学","#化学实验"]},"task_lines":[],"tasks":{},"codeblock_ranges":[]},
