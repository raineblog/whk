受精技术#{1}":[147,175]},"outlinks":[{"title":"蛙胚胎形成和发育过程示意图","target":"image-15-749ac2a.avif","line":38,"embedded":true},{"title":"alt text","target":"image-65-f31c5c3.avif","line":42,"embedded":true},{"title":"alt text","target":"image-51-69fb38e.avif","line":44,"embedded":true},{"title":"alt text","target":"image-52-dd3bd6d.avif","line":46,"embedded":true},{"title":"alt text","target":"image-63-314d6b7.avif","line":48,"embedded":true},{"title":"alt text","target":"image-64-ef835ee.avif","line":50,"embedded":true},{"title":"alt text","target":"image-53-367a4df.avif","line":58,"embedded":true},{"title":"alt text","target":"image-17-8e10ac4.avif","line":74,"embedded":true},{"title":"alt text","target":"image-5.avif","line":86,"embedded":true},{"title":"alt text","target":"image-39-edfb200.avif","line":96,"embedded":true},{"title":"胚胎分割技术示意与显微手术操作","target":"image-16-1a6980b.avif","line":123,"embedded":true}],"metadata":{"title":"胚胎工程详解：受精过程与胚胎移植技术新应用","description":"本文系统阐述哺乳动物胚胎发育的关键环节，包括减数分裂、受精过程、卵裂、囊胚形成及原肠胚分层。重点分析精子获能、卵母细胞成熟、受精卵融合形成雄、雌原核的机制，并描述胚胎分割、体外受精与胚胎移植的技术流程与成功案例，为胚胎工程提供理论与实践支撑。","summary":"胚胎发育全过程解析，涵盖减数分裂、受精、卵裂至原肠胚形成，重点说明胚胎分割与体外受精技术的原理与应用。","tags":["#生物化学","#胚胎工程","#减数分裂","#受精过程","#胚胎分割","#原肠胚","#体外受精","#胚胎移植","#畜牧业","#实验设计","#高中生物","#大学胚胎学","#细胞全能性","#促性腺激素","#超数排卵","#雄原核","#雌原核","#透明带","#卵裂","#胚胎培养"]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"4inoyu","at":1774775770043}},"smart_blocks:docs/science/cell/5.md#---frontmatter---": {"path":null,"embeddings":{"Xenova/multilingual-e5-small":{"vec":[0.03059409,-0.00137844,-0.0568758,-0.04915262,0.12292714,0.00691215,0.03589668,0.06217797,0.0936475,-0.03180711,0.02928274,-0.02277308,0.05401707,-0.01738948,-0.05528697,0.0337165,0.08247507,-0.10132949,-0.02467399,-0.0287889,0.00178489,-0.00904261,-0.08485284,0.02242421,0.08311907,0.03613861,-0.04243416,0.02933548,0.07310918,-0.01281518,-0.05750821,-0.07139169,0.04412281,-0.04514452,0.10154763,0.01798301,-0.05722444,0.00093307,0.03946796,-0.0