
"smart_sources:docs/science/element/si.md": {"path":"docs/science/element/si.md","last_embed":{"hash":null},"embeddings":{},"last_read":{"hash":"omhthg","at":1774774481581},"class_name":"SmartSource","last_import":{"mtime":1774762570762,"size":4239,"at":1774774481634,"hash":"omhthg"},"blocks":{"#---frontmatter---":[1,24],"#碳族元素概述":[26,158],"#碳族元素概述#硅单质":[28,80],"#碳族元素概述#硅单质#硅的物理性质":[30,37],"#碳族元素概述#硅单质#硅的物理性质#{1}":[32,37],"#碳族元素概述#硅单质#硅的化学性质":[38,51],"#碳族元素概述#硅单质#硅的化学性质#{1}":[40,51],"#碳族元素概述#硅单质#硅的工业制取":[52,80],"#碳族元素概述#硅单质#硅的工业制取#{1}":[54,80],"#碳族元素概述#硅的化合物":[81,158],"#碳族元素概述#硅的化合物#二氧化硅":[83,104],"#碳族元素概述#硅的化合物#二氧化硅#{1}":[85,104],"#碳族元素概述#硅的化合物#硅酸":[105,126],"#碳族元素概述#硅的化合物#硅酸#{1}":[107,126],"#碳族元素概述#硅的化合物#硅的应用":[127,158],"#碳族元素概述#硅的化合物#硅的应用#{1}":[129,158]},"outlinks":[],"metadata":{"title":"碳族元素概述详解：硅单质物性与工业制取全面解析","description":"本文系统阐释硅的物理性质、化学反应及工业制取全流程，重点分析晶体硅的晶体结构、与强碱及氢氟酸的反应机理、粗硅到纯硅的还原路线以及硅氯化物转化为纯硅的步骤，并延伸至二氧化硅、硅酸及硅酸盐在玻璃、陶瓷、金刚砂等领域的应用，为高中与大学化学学习提供完整技术框架。","summary":"本文系统梳理硅的晶体结构、化学反应机理以及从粗硅到高纯硅的制备步骤，并探讨其在半导体、光纤及陶瓷中的关键应用，适合高中与大学化学学习。","tags":["#高中化学","#大学化学","#材料科学","#硅","#碳族元素","#半导体","#物理性质","#化学反应","#还原制取","#二氧化硅","#硅酸","#硅酸盐","#金刚砂","#玻璃应用","#实验设计","#工业制备","#高考复习","#竞赛备考"]},"task_lines":[],"tasks":{},"codeblock_ranges":[]},
