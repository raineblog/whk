
"smart_sources:docs/science/genetics/4.md": {"path":"docs/science/genetics/4.md","last_embed":{"hash":null},"embeddings":{},"last_read":{"hash":"bp8j6n","at":1774774481706},"class_name":"SmartSource","last_import":{"mtime":1774762570784,"size":5617,"at":1774774481781,"hash":"bp8j6n"},"blocks":{"#---frontmatter---":[1,27],"#基因工程育种":[29,94],"#基因工程育种#杂种优势":[31,94],"#基因工程育种#杂种优势#遗传学机制":[33,60],"#基因工程育种#杂种优势#遗传学机制#{1}":[35,60],"#基因工程育种#杂种优势#ddd":[61,88],"#基因工程育种#杂种优势#ddd#{1}":[63,88],"#基因工程育种#杂种优势#三系法水稻":[89,90],"#基因工程育种#杂种优势#两系法水稻":[91,92],"#基因工程育种#杂种优势#八倍体小黑麦":[93,94]},"outlinks":[],"metadata":{"title":"基因工程育种详解：杂种优势机制与作物育种应用佳","description":"本文系统阐述基因工程育种中的杂种优势机制，涵盖显性假说、超显性、组-胞质互作及表观遗传调控等理论框架，分析三系法、两系法及八倍体小黑麦的育种策略，提供从基因层面到产量提升的完整技术路线，并探讨其在作物抗逆性、品质改良及可持续农业中的应用前景。","summary":"本文深入解析杂种优势的遗传机制与育种应用，涵盖显性、超显性、上位效应及组-胞质互作等关键理论，并对不同育种体系提供技术路线与实践指南。","tags":["#基因工程","#杂种优势","#育种技术","#显性假说","#超显性","#上位效应","#组-胞质互作","#表观遗传","#HolIB模型","#作物育种","#产量提升","#抗逆性","#CRISPR","#绿色农业","#生物技术","#农业科学","#遗传机制","#近交衰退","#实验设计","#科研创新","#产业应用"]},"task_lines":[],"tasks":{},"codeblock_ranges":[]},
