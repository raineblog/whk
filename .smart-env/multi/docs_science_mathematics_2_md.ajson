
"smart_sources:docs/science/mathematics/2.md": {"path":"docs/science/mathematics/2.md","last_embed":{"hash":null},"embeddings":{},"last_read":{"hash":"16aqbs3","at":1774774481783},"class_name":"SmartSource","last_import":{"mtime":1774762570818,"size":7827,"at":1774774481812,"hash":"16aqbs3"},"blocks":{"#---frontmatter---":[1,26],"#集合与逻辑":[28,270],"#集合与逻辑#基础知识":[30,164],"#集合与逻辑#基础知识#集合的定义":[32,77],"#集合与逻辑#基础知识#集合的定义#{1}":[34,77],"#集合与逻辑#基础知识#集合的运算":[78,145],"#集合与逻辑#基础知识#集合的运算#{1}":[80,145],"#集合与逻辑#基础知识#命题与量词":[146,164],"#集合与逻辑#基础知识#命题与量词#{1}":[148,164],"#集合与逻辑#博弈论":[165,270],"#集合与逻辑#博弈论#组合游戏":[167,188],"#集合与逻辑#博弈论#组合游戏#{1}":[169,188],"#集合与逻辑#博弈论#公平组合游戏":[189,194],"#集合与逻辑#博弈论#公平组合游戏#{1}":[191,194],"#集合与逻辑#博弈论#非公平组合游戏":[195,200],"#集合与逻辑#博弈论#非公平组合游戏#{1}":[197,200],"#集合与逻辑#博弈论#反常游戏":[201,208],"#集合与逻辑#博弈论#反常游戏#{1}":[203,208],"#集合与逻辑#博弈论#P/N-Position":[209,256],"#集合与逻辑#博弈论#P/N-Position#{1}":[211,256],"#集合与逻辑#博弈论#TO BE DONE":[257,270],"#集合与逻辑#博弈论#TO BE DONE#{1}":[259,270]},"outlinks":[],"metadata":{"title":"集合与逻辑详解：博弈论先手后手及策略解析与应用","description":"本文系统阐述集合的定义、要素、子集及运算规律，涵盖并集、交集、补集及德摩根律等；进一步引入命题逻辑与量词的形式化表达；随后深入解析组合博弈论中的公平与非公平游戏、反常规则及P/N位置判定方法，提供从基础到高级的完整技术路线，适用于学术研究与竞赛复习。","summary":"从集合基本概念到博弈论P/N位置，系统梳理运算法则、逻辑量词及游戏策略，提供完整技术框架与应用指南，帮助理解集合论与博弈中的关键机制与决策过程。","tags":["#数学","#集合论","#逻辑","#博弈论","#组合游戏","#公平游戏","#非公平游戏","#反常游戏","#P位置","#N位置","#子集","#并集","#交集","#补集","#命题","#量词","#学术研究","#竞赛复习","#大学生","#逻辑推理"]},"task_lines":[],"tasks":{},"codeblock_ranges":[]},
