:"Gold_foil_experiment_conclusions.svg","line":113,"embedded":true},{"title":"alt text","target":"image-3.avif","line":268,"embedded":true},{"title":"alt text","target":"image-4.avif","line":278,"embedded":true},{"title":"alt text","target":"image-7.avif","line":334,"embedded":true},{"title":"基态激发态","target":"./基态激发态.avif","line":370,"embedded":true},{"title":"alt text","target":"image-6.avif","line":382,"embedded":true},{"title":"光谱的测定","target":"./光谱的测定.avif","line":412,"embedded":true},{"title":"能层与能级","target":"./能层与能级.avif","line":440,"embedded":true},{"title":"能级交错","target":"./能级交错.avif","line":486,"embedded":true},{"title":"轨道表示式","target":"./轨道表示式.avif","line":528,"embedded":true},{"title":"alt text","target":"Helium_atom_QM.svg","line":534,"embedded":true},{"title":"原子轨道","target":"./原子轨道.avif","line":552,"embedded":true},{"title":"轮廓图","target":"./元素周期表轮廓图.avif","line":617,"embedded":true},{"title":"分区","target":"./元素周期表的分区.avif","line":633,"embedded":true},{"title":"十字交叉","target":"./十字交叉法.avif","line":746,"embedded":true},{"title":"元素周期律","target":"./元素周期律.avif","line":754,"embedded":true},{"title":"半径","target":"./共价半径和范德华半径.avif","line":806,"embedded":true},{"title":"电离能","target":"./铍电离能.avif","line":892,"embedded":true},{"title":"第一电离能","target":"./第一电离能.avif","line":906,"embedded":true},{"title":"第一电离能折线图","target":"./第一电离能折线图.avif","line":908,"embedded":true},{"title":"电负性","target":"./电负性.avif","line":924,"embedded":true},{"title":"电负性折线图","target":"./电负性折线图.avif","line":926,"embedded":true}],"metadata":{"title":"原子与元素详解：射线与放射性机制与应用场景","description":"本文系统阐述原子核结构、射线种类及放射性衰变原理，详细解析α、β、γ射线的物理特性、检测技术及其在测厚、能源、医学和同位素标记等实际应用，展示从实验观察到核模型演进的完整技术路线，文中还涉及半衰期概念、核裂变与核聚变的能量释放机制，以及放射性同位素在科研和工业中的标记技术。","summary":"全面解析原子核结构与射线特性，涵盖α、β、γ辐射的物理机制及检测技术，阐述放射性衰变、半衰期及核裂变/聚变能量释放，并探讨同位素标记在测厚、能源与医学中的应用。","tags":["#高中物理","#大学物理","#核物理","#原子科学","#原子结构","#放射性","#射线","#核衰变","#α射线","#β射线","#γ射线","#半衰期","#核裂变","#核聚变","#同位素","#测厚仪","#放射治疗","#实验室演示","#能源技术","#医学诊断","#工业测量","#科研标记","#科普读物","#竞赛备考","#科研人员"]},"task_lines":[],"tasks":{},"codeblock_ranges":[]},
