
"smart_sources:docs/science/element/mg.md": {"path":"docs/science/element/mg.md","last_embed":{"hash":null},"embeddings":{},"last_read":{"hash":"1k1g1e7","at":1774774481581},"class_name":"SmartSource","last_import":{"mtime":1774762570756,"size":1726,"at":1774774481634,"hash":"1k1g1e7"},"blocks":{"#---frontmatter---":[1,24],"#碱土金属概述":[26,53],"#碱土金属概述#镁概述":[28,29],"#碱土金属概述#镁的化学性质":[30,53],"#碱土金属概述#镁的化学性质#{1}":[32,47],"#碱土金属概述#镁的化学性质#海水制镁":[48,53],"#碱土金属概述#镁的化学性质#海水制镁#{1}":[50,53]},"outlinks":[],"metadata":{"title":"碱土金属概述详解：镁的化学性质与海水制备工业","description":"本文系统阐述碱土金属中镁的化学行为，重点分析镁的燃烧反应机理、氧化物稳定性及在海水提取中的工艺路线。通过石灰乳沉淀、酸化溶解、电解熔融等步骤，详细描述从海水到金属镁的工业制备全过程，涵盖反应方程式、能量变化与工艺参数。","summary":"本文深入解析镁的化学性质与海水提取工艺，涵盖燃烧反应、氧化物特性及电解制备全过程，适用于化学学习与工业参考。","tags":["#化学","#无机化学","#镁","#碱土金属","#燃烧反应","#氧化镁","#海水提取","#石灰乳","#酸化溶解","#电解熔融","#工业制备","#防火材料","#实验教学","#大学生","#研究生","#化学爱好者","#能量变化","#反应机理"]},"task_lines":[],"tasks":{},"codeblock_ranges":[]},
